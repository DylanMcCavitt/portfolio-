---
/**
 * TopologyMap — HTML/CSS topology map with natural flow layout.
 * No SVG, no absolute positioning. Uses flexbox/grid for tier layout.
 * Entity data drives pop cards on click.
 */
---

<div class="topo" id="topology-map">
  <!-- Edge tier -->
  <div class="topo__tier">
    <div class="topo__node" data-entity="isp">
      <span class="topo__eyebrow">WAN</span>
      <span class="topo__label">ISP</span>
      <span class="topo__caption">Upstream handoff</span>
    </div>
  </div>

  <div class="topo__connector">
    <div class="topo__line"></div>
  </div>

  <!-- Infrastructure tier -->
  <div class="topo__tier topo__tier--infra">
    <div class="topo__node" data-entity="opnsense">
      <span class="topo__eyebrow">Firewall</span>
      <span class="topo__label">OPNsense</span>
      <span class="topo__caption">Routing, DNS, policy</span>
    </div>
    <div class="topo__node" data-entity="switch">
      <span class="topo__eyebrow">Core Fabric</span>
      <span class="topo__label">Switch</span>
      <span class="topo__caption">Port map hub</span>
    </div>
    <div class="topo__node" data-entity="proxmox">
      <span class="topo__eyebrow">Hypervisor</span>
      <span class="topo__label">Proxmox</span>
      <span class="topo__caption">VM & LXC host</span>
    </div>
  </div>

  <div class="topo__connector">
    <div class="topo__line"></div>
  </div>

  <!-- Service zones tier -->
  <div class="topo__tier topo__tier--zones">
    <!-- Management -->
    <div class="topo__zone" data-entity="management-lane">
      <span class="topo__zone-label">Management</span>
      <div class="topo__node topo__node--vm" data-entity="unifi-vm">
        <span class="topo__eyebrow">VM1</span>
        <span class="topo__label">UniFi VM</span>
        <span class="topo__caption">Controller lane</span>
        <div class="topo__chips">
          <div class="topo__chip" data-entity="unifi-controller">UniFi Controller</div>
        </div>
      </div>
    </div>

    <!-- Services -->
    <div class="topo__zone topo__zone--wide" data-entity="service-lane">
      <span class="topo__zone-label">Services</span>
      <div class="topo__node topo__node--vm" data-entity="shared-vm">
        <span class="topo__eyebrow">VM2</span>
        <span class="topo__label">Shared VM</span>
        <span class="topo__caption">Ubuntu + Docker Compose</span>
        <div class="topo__chips">
          <div class="topo__chip" data-entity="caddy">Caddy</div>
          <div class="topo__chip" data-entity="ingress">Ingress</div>
          <div class="topo__chip" data-entity="homepage">Homepage</div>
          <div class="topo__chip" data-entity="vaultwarden">Vaultwarden</div>
        </div>
      </div>
    </div>

    <!-- Monitoring -->
    <div class="topo__zone" data-entity="signal-lane">
      <span class="topo__zone-label">Monitoring</span>
      <div class="topo__node topo__node--vm" data-entity="kuma-lxc">
        <span class="topo__eyebrow">LXC</span>
        <span class="topo__label">Kuma</span>
        <span class="topo__caption">Independent checks</span>
        <div class="topo__chips">
          <div class="topo__chip" data-entity="uptime-kuma">Uptime Kuma</div>
        </div>
      </div>
    </div>

  </div>

  <div class="topo__connector">
    <div class="topo__line"></div>
  </div>

  <!-- Client tier -->
  <div class="topo__tier topo__tier--clients">
    <div class="topo__node topo__node--small" data-entity="unifi-ap">
      <span class="topo__eyebrow">Wireless</span>
      <span class="topo__label">AP</span>
    </div>
    <div class="topo__node topo__node--small" data-entity="bazzite-pc">
      <span class="topo__eyebrow">Client</span>
      <span class="topo__label">PC</span>
    </div>
    <div class="topo__node topo__node--small" data-entity="jetkvm">
      <span class="topo__eyebrow">Recovery</span>
      <span class="topo__label">KVM</span>
    </div>
    <div class="topo__node topo__node--small" data-entity="nas">
      <span class="topo__eyebrow">Storage</span>
      <span class="topo__label">NAS</span>
    </div>
  </div>

  <!-- Pop card container -->
  <div id="popcard-container"></div>
</div>

<script>
  import '../../scripts/topology.ts';
</script>
