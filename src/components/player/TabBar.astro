---
/**
 * Mobile bottom tab bar — Home · Building · Projects · Resume. Rendered by the
 * player shell on every page so it persists across navigation; CSS shows it
 * only below 820px (where the sidebar is hidden), so desktop is untouched.
 * Active tab derives from the current URL — zero client JS.
 *
 * Graduated from the player-UI prototype (mobile variant B, picked
 * 2026-06-12); styles live in `player.css` under the 820px media block.
 */
const path = Astro.url.pathname;

type TabId = 'home' | 'building' | 'projects' | 'resume';
const active: TabId =
  path === '/' || path.startsWith('/prototype')
    ? 'home'
    : path.startsWith('/library/wip')
      ? 'building'
      : path.startsWith('/journey')
        ? 'resume'
        : 'projects'; // /projects/*, other /library/* playlists

const TABS: { id: TabId; label: string; href: string; glyph: string }[] = [
  { id: 'home', label: 'Home', href: '/', glyph: '⌂' },
  { id: 'building', label: 'Building', href: '/library/wip', glyph: '◐' },
  { id: 'projects', label: 'Projects', href: '/projects', glyph: '▦' },
  { id: 'resume', label: 'Resume', href: '/journey', glyph: '♪' },
];
---

<nav class="tabbar" aria-label="Sections">
  {
    TABS.map((t) => (
      <a
        class:list={{ on: active === t.id }}
        href={t.href}
        aria-current={active === t.id ? 'page' : undefined}
      >
        <span class="ti" aria-hidden="true">{t.glyph}</span>
        {t.label}
      </a>
    ))
  }
</nav>
