---
/**
 * Screenshot rail — horizontally scrolling, scroll-snapping row of shots,
 * ported from the prototype `.shots`/`.shot`/`.sk` CSS (lines 170-195) and the
 * `shotEl()`/`skeleton()` helpers (lines 765-775). Each shot is either a real
 * captured image (lazy `<img>` with explicit width/height for zero CLS) or a
 * CSS skeleton keyed by `kind` (`chart|dash|list|code|phone`) with a hue
 * accent. `phone` shots are 9:16 at 180px; the rest 16:10 at 400px (both
 * capped to the viewport on narrow screens so a full card always fits). A
 * caption gradient overlays both. Pure CSS, zero client JS.
 */
import { isImageShot, type ProjectShot } from '../../data/catalog';

export interface Props {
  shots: ProjectShot[];
  /** Project accent hue, threaded into skeleton accents. */
  hue: string;
}
const { shots, hue } = Astro.props;

/** Explicit pixel dimensions per shot variant, so images reserve layout.
 * `wide` matches the 3:2 frame below; real screenshots cluster ~1.4-1.6 and
 * are letterboxed (object-fit: contain) rather than cropped. */
const DIMS = { wide: { w: 400, h: 267 }, phone: { w: 180, h: 320 } };
const isPhone = (shot: ProjectShot) =>
  isImageShot(shot) ? shot.phone === true : shot.kind === 'phone';
---

<div class="shots" role="group" aria-label="Screenshots" tabindex="0">
  {
    shots.map((shot, i) => {
      const phone = isPhone(shot);
      const dims = phone ? DIMS.phone : DIMS.wide;
      return isImageShot(shot) ? (
        <a
          class:list={['shot', { phone }]}
          href={`#shot-${i}`}
          aria-label={`Expand screenshot: ${shot.cap}`}
        >
          <img
            src={shot.img}
            alt={shot.cap}
            width={dims.w}
            height={dims.h}
            loading="lazy"
            decoding="async"
          />
          <span class="cap">{shot.cap}</span>
        </a>
      ) : (
        <div class:list={['shot', { phone }]}>
          {(
            <div class="sk" data-kind={shot.kind} style={`--sk:${hue}66`} aria-hidden="true">
              {(shot.kind === 'chart' || shot.kind === 'dash' || shot.kind === 'list' || shot.kind === 'phone') && (
                <div class="bar"></div>
              )}
              {shot.kind === 'phone' && <div class="block tall"></div>}
              {shot.kind === 'dash' && (
                <div class="row">
                  <div class="block accent"></div>
                  <div class="lines">
                    <i></i><i></i><i></i><i></i><i></i>
                  </div>
                </div>
              )}
              {shot.kind === 'chart' && (
                <div class="row">
                  <div class="block accent"></div>
                </div>
              )}
              {shot.kind === 'list' && (
                <div class="lines grow">
                  <i></i><i></i><i></i><i></i><i></i><i></i><i></i>
                </div>
              )}
              {shot.kind === 'code' && (
                <div class="lines grow">
                  <i style="width:88%"></i><i style="width:64%"></i>
                  <i style="width:74%"></i><i style="width:52%"></i>
                  <i style="width:81%"></i><i style="width:58%"></i>
                  <i style="width:70%"></i>
                </div>
              )}
              {shot.kind === 'phone' && (
                <div class="lines">
                  <i></i><i></i><i></i>
                </div>
              )}
            </div>
          )}
          <span class="cap">{shot.cap}</span>
        </div>
      );
    })
  }
</div>

{/*
  Zero-JS lightbox: each real screenshot links to `#shot-N`; `:target` reveals
  the matching fixed overlay with the full image. The overlay itself is the
  close link (`#!` matches nothing, so :target clears and nothing scrolls).
*/}
{
  shots.map(
    (shot, i) =>
      isImageShot(shot) && (
        <a class="lightbox" id={`shot-${i}`} href="#!" aria-label="Close screenshot">
          <img src={shot.img} alt={shot.cap} loading="lazy" decoding="async" />
          <span class="lb-cap">{shot.cap}</span>
        </a>
      ),
  )
}

<style>
  .shots {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 18px 30px 8px;
    scroll-snap-type: x mandatory;
    /* the rail still scrolls (swipe / wheel / keys); it just draws no bar */
    scrollbar-width: none;
    /* without this, snap-align: start pulls the first card under the gutter */
    scroll-padding-inline: 30px;
  }
  .shots::-webkit-scrollbar {
    display: none;
  }
  .shot {
    display: block;
  }
  a.shot {
    cursor: zoom-in;
    /* darker mat behind the letterboxed (object-fit: contain) screenshot */
    background: var(--pl-bg);
  }

  /* ---- click-to-expand lightbox (`:target`, zero JS) ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: none;
    place-items: center;
    align-content: center;
    gap: 10px;
    padding: 4vh 4vw;
    background: rgb(0 0 0 / 0.84);
    cursor: zoom-out;
  }
  .lightbox:target {
    display: grid;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 84vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--pl-line);
  }
  .lb-cap {
    font-size: 12.5px;
    color: #e3e6ec;
  }

  .shot {
    /* cap below 400px so a full card (plus a peek of the next) always fits */
    flex: 0 0 min(400px, calc(100vw - 60px));
    /* 3:2 sits in the middle of the real-screenshot ratio cluster (~1.4-1.6),
       so letterbox bars stay minimal while nothing gets cropped */
    aspect-ratio: 3 / 2;
    border-radius: 12px;
    overflow: hidden;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    position: relative;
    scroll-snap-align: start;
  }
  .shot.phone {
    flex: 0 0 min(180px, 60vw);
    aspect-ratio: 9 / 16;
  }

  /* mobile: match the site-wide 18px gutter (player.css responsive block) */
  @media (max-width: 820px) {
    .shots {
      padding-left: 18px;
      padding-right: 18px;
      scroll-padding-inline: 18px;
    }
  }
  .shot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* contain (not cover) so non-3:2 captures show in full, no edge clipping.
       Top-aligned so any vertical letterbox falls to the bottom, under the
       caption gradient rather than over real UI at the top of the shot. */
    object-fit: contain;
    object-position: top;
  }
  .shot .cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    /* shorter, lighter gradient so it reads the caption without masking the
       bottom band of the screenshot where meaningful UI can sit */
    padding: 18px 14px 9px;
    font-size: 11.5px;
    color: var(--pl-text);
    background: linear-gradient(transparent, rgb(0 0 0 / 0.5) 55%, rgb(0 0 0 / 0.82));
  }

  /* ---- skeleton placeholders (prototype `.sk` family) ---- */
  .sk {
    position: absolute;
    inset: 0;
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .sk .bar {
    height: 10px;
    border-radius: 4px;
    background: #ffffff10;
  }
  .sk[data-kind='chart'] .bar { width: 34%; }
  .sk[data-kind='dash'] .bar { width: 46%; }
  .sk[data-kind='list'] .bar { width: 40%; }
  .sk[data-kind='phone'] .bar { width: 52%; }
  .sk .row {
    display: flex;
    gap: 8px;
    flex: 1;
  }
  .sk .block {
    border-radius: 6px;
    background: #ffffff08;
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  .sk .block.tall { flex: 1.2; }
  .sk .block.accent::after {
    content: '';
    position: absolute;
    left: 10%;
    right: 10%;
    bottom: 18%;
    height: 38%;
    border-radius: 4px;
    background: repeating-linear-gradient(
      90deg,
      var(--sk, #50c87844) 0 9%,
      transparent 9% 16%
    );
  }
  .sk .lines {
    flex: 1.4;
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding-top: 4px;
  }
  .sk .lines.grow { flex: 1; }
  .sk .lines i {
    display: block;
    height: 7px;
    border-radius: 3px;
    background: #ffffff0d;
  }
  .sk .lines i:nth-child(2n) { width: 78%; }
  .sk .lines i:nth-child(3n) { width: 62%; }
  /* code/explicit widths win via inline style on each `i`. */
</style>
