---
/**
 * Library view — the project index. A flat, editorial grid of canonical
 * Typographic project cards (#85), filtered by the active sidebar playlist.
 * Used by `/library` (the `all` filter) and `/library/[filter]` for every other
 * playlist. Static, zero client JS.
 *
 * Replaces the old "now playing" hero + numbered tracklist (the Spotify/player
 * metaphor): the index is now an image-free, tile-free card index that reads
 * like a contents page. The player chrome (sidebar + bottom bar + player-state
 * island) still wraps the page via `Player.astro`; it degrades cleanly here
 * because there is no `[data-now-*]` hero or `[data-track-id]` row to hydrate
 * (the island's `applyViewState` guards on those). The shell itself is retired
 * separately once every route has migrated.
 *
 * `PlaylistMenu` (mobile playlist dropdown) still renders at the top so each
 * playlist stays two taps away below 820px; the desktop sidebar covers it.
 */
import PlaylistMenu from './PlaylistMenu.astro';
import ProjectCardGrid from '../ProjectCardGrid.astro';
import { filterCatalog, type PlaylistId } from '../../data/catalog';

export interface Props {
  /** Active playlist filter. */
  filter: PlaylistId;
}
const { filter } = Astro.props;

const list = filterCatalog(filter);

/** Section title for each filter; areas fall back to their own label. */
const SECTION_TITLE: Partial<Record<PlaylistId, string>> = {
  all: 'All work',
  wip: 'Now building',
  School: 'School · Stevens',
  Research: 'Research & retired',
};
const sectionTitle = SECTION_TITLE[filter] ?? filter;
const count = list.length;
---

<div class="view">
  <PlaylistMenu active={filter} />

  <header class="libhead">
    <p class="libhead__count">{count} {count === 1 ? 'project' : 'projects'}</p>
    <h1 class="libhead__title">{sectionTitle}</h1>
  </header>

  <div class="libgrid">
    <ProjectCardGrid projects={list} />
  </div>
</div>

<style>
  /* Shell gutters match the player primitives (`.head`/`.listwrap`: 30px desktop,
     18px mobile) so the index lines up with the rest of the main panel. */
  .libhead {
    padding: 30px 30px 14px;
  }
  .libhead__count {
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .libhead__title {
    margin-top: 6px;
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--pl-text);
  }
  .libgrid {
    padding: 6px 30px 52px;
  }

  @media (max-width: 820px) {
    .libhead {
      padding: 22px 18px 12px;
    }
    .libgrid {
      padding: 4px 18px 40px;
    }
  }
</style>
