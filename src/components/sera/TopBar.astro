---
import TopNavLink from './TopNavLink.astro';
import TopActions from './TopActions.astro';

const NAV = [
  { to: '/about', label: 'about' },
  { to: '/projects', label: 'projects' },
  { to: '/experience', label: 'experience' },
  { to: '/log', label: 'log' },
  { to: '/contact', label: 'contact' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (to: string) =>
  pathname === to || pathname.startsWith(`${to}/`);
---

<header class="top-bar">
  <div class="top-bar__inner">
    <a href="/" class="top-bar__brand">Dylan McCavitt</a>
    <div class="top-bar__desktop">
      <nav class="top-bar__nav" aria-label="Primary">
        {
          NAV.map((item, i) => (
            <TopNavLink
              index={i + 1}
              label={item.label}
              to={item.to}
              active={isActive(item.to)}
            />
          ))
        }
      </nav>
      <div class="top-bar__actions">
        <TopActions />
      </div>
    </div>
    <details class="top-bar__mobile-menu">
      <summary class="top-bar__mobile-toggle" aria-label="Open navigation menu">
        <span class="top-bar__mobile-toggle-line"></span>
        <span class="top-bar__mobile-toggle-line"></span>
        <span class="top-bar__mobile-toggle-line"></span>
      </summary>
      <div class="top-bar__mobile-panel">
        <nav class="top-bar__mobile-nav" aria-label="Primary mobile">
          {
            NAV.map((item, i) => (
              <a
                href={item.to}
                class:list={[
                  'top-bar__mobile-link',
                  isActive(item.to) && 'top-bar__mobile-link--active',
                ]}
                aria-current={isActive(item.to) ? 'page' : undefined}
              >
                <span class="top-bar__mobile-link-meta">
                  <span class="top-bar__mobile-link-idx">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span>{item.label}</span>
                </span>
                <span aria-hidden="true">→</span>
              </a>
            ))
          }
        </nav>
        <div class="top-bar__mobile-actions">
          <TopActions />
        </div>
      </div>
    </details>
  </div>
</header>

<style>
  .top-bar {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklch, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .top-bar__inner {
    max-width: 64rem;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .top-bar__brand {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .top-bar__brand:hover {
    text-decoration: none;
    color: var(--accent);
  }
  .top-bar__desktop {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .top-bar__nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .top-bar__actions {
    padding-left: 12px;
    border-left: 1px solid var(--line);
  }
  .top-bar__mobile-menu {
    display: none;
    position: relative;
  }
  .top-bar__mobile-toggle {
    list-style: none;
    display: inline-grid;
    gap: 4px;
    width: 32px;
    height: 32px;
    padding: 8px 7px;
    border: 1px solid var(--line);
    background: var(--card);
    cursor: pointer;
    transition:
      border-color 0.25s var(--ease),
      background 0.25s var(--ease);
  }
  .top-bar__mobile-toggle::-webkit-details-marker {
    display: none;
  }
  .top-bar__mobile-toggle-line {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--ink);
  }
  .top-bar__mobile-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    width: min(320px, calc(100vw - 32px));
    padding: 10px;
    border: 1px solid var(--line);
    background: color-mix(in oklch, var(--bg) 96%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .top-bar__mobile-nav {
    display: flex;
    flex-direction: column;
  }
  .top-bar__mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 10px;
    border: 1px solid transparent;
    color: var(--muted);
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-decoration: none;
    transition:
      border-color 0.2s var(--ease),
      color 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .top-bar__mobile-link:hover,
  .top-bar__mobile-link--active {
    color: var(--ink);
    border-color: var(--line);
    text-decoration: none;
  }
  .top-bar__mobile-link-meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .top-bar__mobile-link-idx {
    font-family: var(--font-mono);
    font-size: 10px;
    opacity: 0.6;
  }
  .top-bar__mobile-actions {
    margin-top: 8px;
    padding-top: 10px;
    border-top: 1px solid var(--line);
  }
  .top-bar__mobile-actions :global(.top-actions) {
    width: 100%;
    justify-content: flex-end;
  }
  .top-bar__mobile-menu[open] .top-bar__mobile-toggle {
    border-color: var(--ink);
  }

  @media (max-width: 760px) {
    .top-bar__inner {
      height: 60px;
      padding: 0 16px;
    }
    .top-bar__brand {
      font-size: 12.5px;
      letter-spacing: 0.12em;
    }
    .top-bar__desktop {
      display: none;
    }
    .top-bar__mobile-menu {
      display: block;
    }
  }
</style>
