---
/**
 * Project detail view — one static page per catalog project, ported from the
 * prototype `renderProject()` (`15-player-v4.html` lines 823-867). Static,
 * zero client JS; the scroll rail is pure CSS. The big-play button renders a
 * stable DOM contract (`data-play` / `data-project`) for #24 — no behavior.
 */
import PlayerLayout from '../../layouts/Player.astro';
import ProjectArt from '../../components/player/ProjectArt.astro';
import StatusBadge from '../../components/player/StatusBadge.astro';
import ShotsRail from '../../components/player/ShotsRail.astro';
import CreditsList from '../../components/player/CreditsList.astro';
import ProjectCardGrid from '../../components/ProjectCardGrid.astro';
import { CATALOG, getProjectById, type Project } from '../../data/catalog';
import { projectMeta } from '../../lib/seo';

export function getStaticPaths() {
  return CATALOG.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}
const { project } = Astro.props as Props;

// Fallback for direct prop typing; getStaticPaths always supplies `project`.
const p = project ?? getProjectById(Astro.params.id as string)!;

const related = CATALOG.filter((o) => o.area === p.area && o.id !== p.id).slice(0, 5);
const meta = projectMeta(p);
---

<PlayerLayout title={meta.title} meta={meta} active={p.area} now={p}>
  <div class="view">
    <div class="head">
      <a class="back" href="/library">Library</a>
      <div class="hero">
        <ProjectArt sym={p.sym} hue={p.hue} size="lg" />
        <div class="info">
          <span class="kind">{p.area} · {p.year}</span>
          <h1>{p.title}</h1>
          <p>{p.line}</p>
          <div class="meta">
            <StatusBadge status={p.status} />
            <span><b>{p.activity}</b></span>
          </div>
        </div>
      </div>
    </div>

    <div class="actions">
      <button
        class="bigplay"
        type="button"
        title="play"
        aria-label={`Play ${p.title}`}
        data-play
        data-project={p.id}
      ></button>
      {
        p.links.map(([label, url]) => (
          <a class="act-link" href={url} target="_blank" rel="noopener">
            {label}
          </a>
        ))
      }
    </div>

    {
      p.metrics.length > 0 && (
        <div class="stats">
          {p.metrics.map(([value, label]) => (
            <div class="stat">
              <b>{value}</b>
              <span>{label}</span>
            </div>
          ))}
        </div>
      )
    }

    <ShotsRail shots={p.shots} hue={p.hue} />

    <div class="pbody">
      <div>
        <h3>About</h3>
        {p.about.map((para) => <p>{para}</p>)}
        <h3>Liner notes</h3>
        <ul class="notes">
          {p.notes.map((note) => <li>{note}</li>)}
        </ul>
      </div>
      <div>
        <h3>Credits</h3>
        <CreditsList rows={p.stack} />
      </div>
    </div>

    {
      related.length > 0 && (
        <div class="more">
          <h3>More from {p.area}</h3>
          <ProjectCardGrid projects={related} />
        </div>
      )
    }
  </div>
</PlayerLayout>

<!-- All styling comes from the player.css primitives (`.hero`, `.actions`,
     `.bigplay`, `.back`, `.stats`, `.pbody`, `.more`, ...) — no scoped copy,
     so the shared mobile gutter overrides there apply here too. -->
