---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/sera/PageHeader.astro';
import Pager from '../components/sera/Pager.astro';
import SeraLabel from '../components/sera/SeraLabel.astro';

type Entry = [year: string, name: string, detail: string];

const education: Entry[] = [
  ['2026', 'Stevens Institute of Technology', 'M.S. Computer Science'],
  ['2019', 'Syracuse University', 'B.S. Economics'],
];

const work: Entry[] = [
  ['2025', "Bella's Beads", 'Freelance Full-Stack Developer'],
  ['2025', 'Manhattan Board of Elections', 'IT Support'],
  ['2023 - 24', 'Kroll, Inc.', 'Associate, Cyber Strategy & Risk'],
  ['2020 - 23', 'Paul, Weiss', 'Practice Assistant, Private Funds'],
];
---

<Base title="Experience — Dylan McCavitt" description="Education and work history for Dylan McCavitt.">
  <main class="experience">
    <PageHeader
      kicker="03 / experience"
      title="Dylan McCavitt"
      sub="Software engineer, NYC"
    />

    <a
      href="/resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="resume-btn"
    >
      <span>View / download resume</span>
      <span class="resume-btn__arrow" aria-hidden="true">↗</span>
    </a>

    <section class="experience__section">
      <SeraLabel as="h2" tone="muted" class="experience__kicker">.education</SeraLabel>
      <dl class="experience__list">
        {education.map(([year, name, detail]) => (
          <div class="experience__row">
            <dt class="experience__year">{year}</dt>
            <dd class="experience__item">
              <div class="experience__name">{name}</div>
              <div class="experience__detail">{detail}</div>
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="experience__section">
      <SeraLabel as="h2" tone="muted" class="experience__kicker">.experience</SeraLabel>
      <dl class="experience__list">
        {work.map(([year, name, detail]) => (
          <div class="experience__row">
            <dt class="experience__year">{year}</dt>
            <dd class="experience__item">
              <div class="experience__name">{name}</div>
              <div class="experience__detail">{detail}</div>
            </dd>
          </div>
        ))}
      </dl>
    </section>

    <div class="experience__pager">
      <Pager
        prev={{ href: '/projects', label: 'Projects' }}
        next={{ href: '/log', label: 'Log' }}
        prevKicker="Prev"
        nextKicker="Next"
      />
    </div>
  </main>
</Base>

<style>
  .experience {
    max-width: 42rem;
    margin: 0 auto;
    padding: 64px 24px;
  }

  .resume-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    padding: 10px 16px;
    background: var(--ink);
    color: var(--bg);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.25s var(--ease);
  }
  .resume-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in oklch, var(--bg) 25%, transparent),
      transparent
    );
    transform: translateX(-100%);
    transition: transform 0.6s var(--ease);
    pointer-events: none;
  }
  .resume-btn:hover {
    text-decoration: none;
  }
  .resume-btn:hover::after {
    transform: translateX(100%);
  }
  .resume-btn__arrow {
    display: inline-block;
    transition: transform 0.3s var(--ease);
  }
  .resume-btn:hover .resume-btn__arrow {
    transform: translate(2px, -2px);
  }

  .experience__section {
    margin-top: 48px;
  }
  .experience__kicker {
    display: block;
    margin-bottom: 20px;
  }

  .experience__list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .experience__row {
    display: grid;
    grid-template-columns: 90px 1fr;
    column-gap: 24px;
    align-items: start;
  }
  .experience__year {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding-top: 2px;
  }
  .experience__name {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.35;
  }
  .experience__detail {
    margin-top: 4px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  .experience__pager {
    margin-top: 64px;
  }

  @media (max-width: 560px) {
    .experience__row {
      grid-template-columns: 72px 1fr;
      column-gap: 16px;
    }
  }
</style>
