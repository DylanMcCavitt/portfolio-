---
import Base from '../layouts/Base.astro';
---

<Base title="Dylan McCavitt" showPaletteNav={true}>
  <main>
    <section class="about" id="about">
      <h2 class="section-heading section-heading--about">[[about]]</h2>
      <p class="about__text">
        I'm a software engineer based in Portland who builds web applications,
        manages infrastructure, and cares about making software that's reliable
        and easy to understand. I'm currently looking for my next role — somewhere
        I can work on real problems with a team that values clarity and quality.
      </p>
    </section>

    <section class="projects" id="projects">
      <h2 class="section-heading section-heading--projects">[[projects]]</h2>
      <div class="projects__listing">
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/homelab/" class="projects__link projects__link--1">homelab/</a>
          <span class="projects__desc">— proxmox, opnsense, ansible</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/bella/" class="projects__link projects__link--2">bella/</a>
          <span class="projects__desc">— next.js saas, supabase, stripe</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/nohard/" class="projects__link projects__link--3">nohard/</a>
          <span class="projects__desc">— developer cli tool</span>
        </div>
        <div class="projects__row">
          <span class="projects__chevron">{'>'}</span>
          <a href="/projects/work-orders/" class="projects__link projects__link--4">work-orders/</a>
          <span class="projects__desc">— school district maintenance</span>
        </div>
      </div>
    </section>

    <section class="contact" id="contact">
      <h2 class="section-heading section-heading--contact">[[contact]]</h2>
      <div class="contact__links">
        <a href="https://github.com/DylanMcCavitt" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com/in/dylanmccavitt" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:dylan@example.com">Email</a>
      </div>
    </section>
  </main>
</Base>

<style>
  /* Section headings */
  .section-heading {
    font-size: var(--text-xl);
    font-weight: 600;
    opacity: 0.7;
    text-transform: lowercase;
    margin-bottom: var(--space-5);
  }
  .section-heading--projects { color: var(--nav-1); }
  .section-heading--about { color: var(--nav-2); }
  .section-heading--contact { color: var(--nav-3); }

  /* About */
  .about {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-7) var(--space-5) var(--space-6);
  }
  .about__text {
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* Projects — terminal listing */
  .projects {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-6);
  }
  .projects__listing {
    line-height: 2.4;
  }
  .projects__row {
    white-space: nowrap;
  }
  .projects__chevron {
    color: var(--accent);
    margin-right: var(--space-2);
  }
  .projects__link {
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px dashed currentColor;
    border-bottom-color: rgba(255, 255, 255, 0.2);
  }
  .projects__link:hover {
    text-decoration: none;
    border-bottom-style: solid;
    border-bottom-color: currentColor;
  }
  .projects__link--1 { color: var(--nav-1); }
  .projects__link--2 { color: var(--nav-2); }
  .projects__link--3 { color: var(--nav-3); }
  .projects__link--4 { color: var(--nav-4); }
  .projects__desc {
    color: var(--text-muted);
    margin-left: var(--space-3);
  }

  /* Contact */
  .contact {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-5) var(--space-7);
  }
  .contact__links {
    display: flex;
    gap: var(--space-6);
  }
  .contact__links a {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .contact__links a:hover { color: var(--text); }
</style>
