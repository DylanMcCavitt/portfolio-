---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TopologyMap from '../../components/topology/TopologyMap.astro';
import '../../styles/topology.css';
---

<Base title="Homelab Topology — Dylan McCavitt" description="Interactive topology map of Dylan's homelab infrastructure">
  <div class="topology-page">
    <div class="topology-breadcrumb">
      <Breadcrumb slug="topology" section="projects" parent={{ label: "homeserver", href: "/projects/homeserver/" }} />
    </div>

    <TopologyMap />

    <nav class="topology-nav">
      <a href="/projects/homeserver/" class="topology-nav__link">&larr;</a>
      <a href="/projects/bellas-beads/" class="topology-nav__link">&rarr;</a>
    </nav>
    <nav class="topology-bottom">
      <a href="/" class="topology-bottom__link">home</a>
      <a href="/resume/" class="topology-bottom__link">experience</a>
      <a href="/#contact" class="topology-bottom__link">contact</a>
    </nav>
  </div>
</Base>
