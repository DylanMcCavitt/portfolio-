---
import Base from '../layouts/Base.astro';
import PageHeader from '../components/sera/PageHeader.astro';
import IconButton from '../components/sera/IconButton.astro';
import Pager from '../components/sera/Pager.astro';

const links = [
  {
    label: 'Email',
    href: 'mailto:dylanmccavitt@outlook.com',
    icon: 'email',
  },
  {
    label: 'GitHub',
    href: 'https://github.com/DylanMcCavitt/',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/dylan-mccavitt',
    icon: 'linkedin',
  },
  {
    label: 'X',
    href: 'https://x.com/dylanmccavitt_',
    icon: 'x',
  },
];
---

<Base
  title="Contact — Dylan McCavitt"
  description="Get in touch with Dylan McCavitt."
>
  <main class="contact-page">
    <PageHeader
      kicker="05 / contact"
      title="Get in touch"
      sub="Open to opportunities or collaboration. Reach out wherever works."
    />
    <ul class="contact-page__list">
      {
        links.map(({ label, href, icon }) => (
          <li>
            <IconButton
              href={href}
              ariaLabel={label}
              external={href.startsWith('http')}
            >
              {
                icon === 'email' && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true"
                  >
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m2 4 10 8 10-8"></path>
                  </svg>
                )
              }
              {
                icon === 'github' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-2.02c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.25 3.33.96.1-.74.4-1.25.72-1.53-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.17 1.18A10.94 10.94 0 0 1 12 6.8c.98 0 1.97.13 2.89.38 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"></path>
                  </svg>
                )
              }
              {
                icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
                  </svg>
                )
              }
              {
                icon === 'x' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
                  </svg>
                )
              }
            </IconButton>
          </li>
        ))
      }
    </ul>
    <div class="contact-page__pager">
      <Pager prev={{ href: '/log', label: 'log' }} />
    </div>
  </main>
</Base>

<style>
  .contact-page {
    max-width: 36rem;
    margin: 0 auto;
    padding: 64px 24px;
  }
  .contact-page__list {
    list-style: none;
    margin: 40px 0 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 24px;
  }
  .contact-page__pager {
    margin-top: 48px;
  }
</style>
