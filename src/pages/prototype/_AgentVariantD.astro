---
/**
 * PROTOTYPE — throwaway, do not ship. Variant D: "DJ in the shell".
 *
 * Eve as the portfolio DJ, embedded in the REAL player shell (sidebar +
 * player bar + tab bar): the chat fits the existing brand instead of replacing
 * it. You ask; she "queues" projects as tracklist rows that link straight to
 * /projects/<id> — the agent literally builds a playlist. The reveal/streaming
 * is owned by the shared `_agentProto.client.ts`; this file only wires the
 * `data-proto-*` hooks and styles the chat region. Self-contained, no props.
 */
import Sidebar from '../../components/player/Sidebar.astro';
import PlayerBar from '../../components/player/PlayerBar.astro';
import TabBar from '../../components/player/TabBar.astro';
import {
  AGENT_NAME,
  GREETING,
  SUBGREETING,
  SUGGESTED,
  CONVERSATION,
  CONTACT,
  projectById,
  trackById,
} from './_agentData';
---

<div class="player-body" data-proto-root>
  <div class="body">
    <nav class="sidebar-nav" aria-label="Primary">
      <Sidebar active="home" />
    </nav>

    <main class="main dj" id="main" tabindex="-1">
      <div class="dj-scroll">
        {/* ---- empty state: the DJ booth ---- */}
        <section class="dj-empty" data-proto-empty>
          <div class="hero dj-hero">
            <div class="art lg disc dj-disc" style="--a:var(--pl-accent)" aria-hidden="true">E</div>
            <div class="dj-hero-copy">
              <p class="kind">{AGENT_NAME} · Portfolio DJ</p>
              <h1>Ask the DJ about Dylan</h1>
              <p>{GREETING}</p>
              <p class="meta">
                <span class="eq" aria-hidden="true"><i></i><i></i><i></i></span>
                {SUBGREETING}
              </p>
            </div>
          </div>

          <div class="dj-chips" role="list" aria-label="Suggested questions">
            {
              SUGGESTED.map((s) => (
                <button class="act-link dj-chip" type="button" data-proto-send data-turn={s.id} role="listitem">
                  <span class="dj-chip-label">{s.label}</span>
                  {s.hint && <span class="dj-chip-hint">{s.hint}</span>}
                </button>
              ))
            }
          </div>
        </section>

        {/* ---- the conversation: pre-rendered, revealed by the driver ---- */}
        <div class="dj-thread" data-proto-thread>
          {
            CONVERSATION.map((turn) => (
              <article class="dj-turn" data-proto-turn={turn.id} hidden>
                <header class="dj-q">
                  <span class="dj-q-tag">You asked</span>
                  <p class="dj-q-text" data-proto-user>{turn.q}</p>
                </header>

                <div class="dj-typing" data-proto-typing>
                  <span class="eq" aria-hidden="true"><i></i><i></i><i></i></span>
                  <span class="dj-typing-label">{AGENT_NAME} is queuing tracks…</span>
                  <ul class="dj-trace">
                    {turn.trace.map((line) => <li>{line}</li>)}
                  </ul>
                </div>

                <div class="dj-answer" data-proto-answer hidden>
                  <div class="dj-eve">
                    <span class="dj-eve-mark" aria-hidden="true"></span>
                    <span class="dj-eve-name">{AGENT_NAME}</span>
                    <details class="dj-used">
                      <summary>used {turn.trace.length} tool{turn.trace.length === 1 ? '' : 's'}</summary>
                      <ul>
                        {turn.trace.map((line) => <li>{line}</li>)}
                      </ul>
                    </details>
                  </div>

                  {
                    turn.answer.map((block) => {
                      if (block.kind === 'text') {
                        return <p class="dj-text">{block.text}</p>;
                      }
                      if (block.kind === 'projects') {
                        return (
                          <div class="dj-queue">
                            <div class="dj-queue-head">
                              <span class="dj-queue-title">Queued for you</span>
                              <span class="dj-queue-count">
                                {block.ids.length} track{block.ids.length === 1 ? '' : 's'}
                              </span>
                            </div>
                            <div class="list-head dj-head">
                              <span>#</span>
                              <span aria-hidden="true" />
                              <span>Track</span>
                              <span class="dj-col-status">Status</span>
                              <span class="dj-col-len">Activity</span>
                            </div>
                            <ol class="tracklist">
                              {
                                block.ids.map((id, i) => {
                                  const p = projectById(id);
                                  return (
                                    <li>
                                      <a class="track dj-track" href={`/projects/${p.id}`}>
                                        <span class="n">
                                          <span class="eq" aria-hidden="true"><i></i><i></i><i></i></span>
                                          <span class="num">{i + 1}</span>
                                          <span class="hoverplay" aria-hidden="true" />
                                        </span>
                                        <span class="art dj-art" style={`--a:${p.hue}`} aria-hidden="true">{p.sym}</span>
                                        <span class="t">
                                          <b>{p.title}</b>
                                          <small>{p.area}</small>
                                        </span>
                                        <span class="dj-col-status">
                                          <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
                                        </span>
                                        <span class="len dj-col-len">{p.activity}</span>
                                      </a>
                                    </li>
                                  );
                                })
                              }
                            </ol>
                          </div>
                        );
                      }
                      if (block.kind === 'resume') {
                        return (
                          <div class="dj-queue dj-queue-album">
                            <div class="dj-queue-head">
                              <span class="dj-queue-title">The Journey · résumé</span>
                              <span class="dj-queue-count">{block.trackIds.length} tracks</span>
                            </div>
                            <div class="list-head dj-head">
                              <span>#</span>
                              <span aria-hidden="true" />
                              <span>Track</span>
                              <span class="dj-col-status" />
                              <span class="dj-col-len">Era</span>
                            </div>
                            <ol class="tracklist">
                              {
                                block.trackIds.map((id, i) => {
                                  const t = trackById(id);
                                  return (
                                    <li>
                                      <a class:list={['track', 'dj-track', { playing: t.current }]} href={`/journey/${t.id}`}>
                                        <span class="n">
                                          <span class="eq" aria-hidden="true"><i></i><i></i><i></i></span>
                                          <span class="num">{i + 1}</span>
                                          <span class="hoverplay" aria-hidden="true" />
                                        </span>
                                        <span class="art dj-art" style={`--a:${t.hue}`} aria-hidden="true">{t.sym}</span>
                                        <span class="t">
                                          <b>{t.title}</b>
                                          <small>{t.role}</small>
                                        </span>
                                        <span class="dj-col-status">
                                          {t.current && <span class="badge live">Now</span>}
                                        </span>
                                        <span class="len dj-col-len">{t.when}</span>
                                      </a>
                                    </li>
                                  );
                                })
                              }
                            </ol>
                          </div>
                        );
                      }
                      if (block.kind === 'contact') {
                        return (
                          <div class="dj-contact">
                            <div class="dj-contact-top">
                              <span class="dj-eve-mark lg" aria-hidden="true"></span>
                              <div>
                                <b class="dj-contact-name">Dylan McCavitt</b>
                                <span class="badge live">{CONTACT.status}</span>
                              </div>
                            </div>
                            <div class="dj-contact-stats">
                              <div class="stat"><b>{CONTACT.location}</b><span>Based in</span></div>
                              <div class="stat"><b>Full-time</b><span>Open to</span></div>
                            </div>
                            <div class="dj-contact-links">
                              <a class="act-link" href={`mailto:${CONTACT.email}`}>{CONTACT.email} ↗</a>
                              <a class="act-link" href={CONTACT.github} target="_blank" rel="noopener">GitHub ↗</a>
                              <a class="act-link" href={CONTACT.resume} target="_blank" rel="noopener">Résumé.pdf ↗</a>
                            </div>
                          </div>
                        );
                      }
                      if (block.kind === 'links') {
                        return (
                          <div class="dj-chips dj-next" role="list" aria-label="Next questions">
                            {
                              SUGGESTED.map((s) => (
                                <button class="act-link dj-chip" type="button" data-proto-send data-turn={s.id} role="listitem">
                                  <span class="dj-chip-label">{s.label}</span>
                                </button>
                              ))
                            }
                          </div>
                        );
                      }
                      return null;
                    })
                  }
                </div>
              </article>
            ))
          }
        </div>
      </div>

      {/* ---- composer docked at the bottom of .main (PlayerBar/TabBar stay put) ---- */}
      <div class="dj-dock">
        <form class="dj-form" data-proto-form>
          <label class="sr-only" for="dj-input">Ask {AGENT_NAME} about Dylan</label>
          <span class="dj-form-icon" aria-hidden="true"></span>
          <input
            id="dj-input"
            class="dj-input"
            data-proto-input
            type="text"
            autocomplete="off"
            placeholder="Ask the DJ — e.g. what's he building right now?"
          />
          <button class="dj-reset" type="button" data-proto-reset>clear</button>
          <button class="dj-send" type="submit" aria-label="Ask Eve"></button>
        </form>
      </div>
    </main>
  </div>

  <PlayerBar now={projectById('exit-manager')} />
  <TabBar />
</div>

<style>
  /* The shell chrome (`.player-body`, `.body`, `.sidebar`, `.main`, `.tabbar`,
     `.playerbar`) + primitives (`.hero`, `.act-link`, `.art`, `.badge`, `.eq`,
     `.track`, `.list-head`, `.stat`) are all global in player.css. We reuse
     them verbatim and only add the chat-specific layer below, scoped so it
     can't bleed into the other variants. */

  /* Turn the main column into a flex stack: the thread scrolls, the composer
     docks. (Overrides the global `.main { overflow-y: auto }`.) */
  .main.dj {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .dj-scroll {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  /* ---- empty state: the DJ booth ---- */
  .dj-empty {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: clamp(22px, 5vh, 44px) 30px 26px;
  }
  .proto-started .dj-empty {
    display: none;
  }
  .dj-hero {
    gap: 28px;
  }
  .dj-hero-copy {
    min-width: 0;
  }
  .dj-disc {
    box-shadow: 0 18px 44px rgb(0 0 0 / 0.5);
  }
  @media (prefers-reduced-motion: no-preference) {
    .dj-disc {
      animation: dj-spin 9s linear infinite;
    }
  }
  @keyframes dj-spin {
    to {
      transform: rotate(360deg);
    }
  }
  .dj-hero .meta .eq {
    height: 11px;
  }

  .dj-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .dj-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .dj-chip-hint {
    font-family: var(--pl-mono);
    font-size: 10.5px;
    color: var(--pl-faint);
    border-left: 1px solid var(--pl-line);
    padding-left: 10px;
  }
  .dj-chip:hover .dj-chip-hint {
    color: var(--pl-accent);
  }

  /* ---- thread ---- */
  .dj-thread {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 24px 30px 28px;
  }
  .dj-turn {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  /* author display on .dj-turn/.dj-answer/.dj-typing out-specifies the UA
     `[hidden]` rule, so restore the hide explicitly for the driver toggles. */
  .dj-turn[hidden] {
    display: none;
  }

  .dj-q {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dj-q-tag {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .dj-q-text {
    font-size: clamp(17px, 2.4vw, 23px);
    font-weight: 700;
    letter-spacing: -0.4px;
    color: var(--pl-text);
  }

  .dj-typing {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 12px;
    padding: 12px 16px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 12px;
  }
  .dj-typing[hidden] {
    display: none;
  }
  .dj-typing .eq {
    height: 14px;
  }
  .dj-typing-label {
    font-size: 12.5px;
    color: var(--pl-dim);
  }
  .dj-trace {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 14px;
    width: 100%;
  }
  .dj-trace li {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }
  .dj-trace li::before {
    content: '→ ';
    color: var(--pl-accent);
  }

  .dj-answer {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .dj-answer[hidden] {
    display: none;
  }

  .dj-eve {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .dj-eve-mark {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--pl-tile-line);
    background: radial-gradient(circle at 50% 50%, var(--pl-bg) 0 22%, var(--pl-accent) 24% 100%);
  }
  .dj-eve-mark.lg {
    width: 52px;
    height: 52px;
  }
  .dj-eve-name {
    font-size: 13px;
    font-weight: 600;
  }
  .dj-used {
    position: relative;
    margin-left: auto;
  }
  .dj-used summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--pl-mono);
    font-size: 10.5px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
    padding: 5px 11px;
    border: 1px solid var(--pl-line);
    border-radius: 99px;
  }
  .dj-used summary::-webkit-details-marker {
    display: none;
  }
  .dj-used summary:hover,
  .dj-used[open] summary {
    color: var(--pl-text);
    border-color: var(--pl-faint);
  }
  .dj-used ul {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    z-index: 5;
    min-width: 240px;
    list-style: none;
    display: grid;
    gap: 5px;
    padding: 11px 13px;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 10px;
    box-shadow: 0 16px 40px rgb(0 0 0 / 0.5);
  }
  .dj-used li {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-dim);
  }

  .dj-text {
    color: var(--pl-dim);
    font-size: 14px;
    max-width: 64ch;
  }

  /* ---- queued playlist (projects + résumé as tracks) ---- */
  .dj-queue {
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    padding: 6px 8px 8px;
  }
  .dj-queue-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 12px 4px;
  }
  .dj-queue-title {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.4px;
  }
  .dj-queue-count {
    font-family: var(--pl-mono);
    font-size: 10.5px;
    color: var(--pl-faint);
  }

  /* same 5-cell rhythm as the global tracklist, with an album-art column added.
     Selectors are parent-qualified (and `.art.dj-art`) so they out-specify the
     global `.track`/`.list-head`/`.art` rules under any scope strategy. */
  .dj-queue .dj-head,
  .dj-queue .dj-track {
    grid-template-columns: 30px 40px minmax(0, 1fr) auto 96px;
    gap: 14px;
  }
  .dj-queue .dj-head {
    padding: 6px 12px;
  }
  .dj-queue .dj-track {
    padding: 9px 12px;
  }
  @media (hover: hover) {
    .dj-queue .dj-track:hover {
      background: var(--pl-panel-hi);
    }
  }
  .art.dj-art {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    font-size: 13px;
  }
  .art.dj-art::after {
    height: 4px;
  }
  .dj-col-status {
    display: flex;
    align-items: center;
  }
  .dj-col-len {
    text-align: right;
    white-space: nowrap;
  }

  /* ---- contact panel ---- */
  .dj-contact {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 560px;
    padding: 18px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
  }
  .dj-contact-top {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .dj-contact-name {
    display: block;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .dj-contact-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .dj-contact-stats .stat {
    flex: 1;
    min-width: 130px;
  }
  .dj-contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  /* ---- docked composer ---- */
  .dj-dock {
    flex: 0 0 auto;
    padding: 14px 30px;
    background: var(--pl-side);
    border-top: 1px solid var(--pl-line);
  }
  .dj-form {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 760px;
    margin: 0 auto;
    padding: 6px 6px 6px 14px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    transition: border-color 0.15s;
  }
  .dj-form:focus-within {
    border-color: var(--pl-accent);
  }
  .dj-form-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, var(--pl-bg) 0 26%, var(--pl-accent) 28% 100%);
  }
  .dj-input {
    flex: 1;
    min-width: 0;
    padding: 8px 0;
    background: none;
    border: none;
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 14px;
  }
  .dj-input:focus {
    outline: none;
  }
  .dj-input::placeholder {
    color: var(--pl-faint);
  }
  .dj-reset {
    display: none;
    font-family: var(--pl-mono);
    font-size: 10.5px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
    padding: 7px 13px;
    border: 1px solid var(--pl-line);
    border-radius: 99px;
  }
  .dj-reset:hover {
    color: var(--pl-text);
    border-color: var(--pl-faint);
  }
  .proto-started .dj-reset {
    display: inline-flex;
  }
  .dj-send {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: 10px;
    background: var(--pl-accent);
    display: grid;
    place-items: center;
    transition: transform 0.12s, filter 0.12s;
  }
  .dj-send::after {
    content: '';
    width: 0;
    height: 0;
    border-top: 6px solid transparent;
    border-bottom: 6px solid transparent;
    border-left: 11px solid var(--pl-ink);
    margin-left: 3px;
  }
  .dj-send:hover {
    filter: brightness(1.08);
    transform: scale(1.05);
  }

  /* ---- mobile: shell already drops to one column + shows the tab bar ---- */
  @media (max-width: 820px) {
    .dj-empty {
      padding: 20px 18px 18px;
    }
    .dj-thread {
      padding: 20px 18px 22px;
      gap: 22px;
    }
    .dj-dock {
      padding: 12px 14px calc(12px + env(safe-area-inset-bottom, 0px));
    }
    .dj-scroll {
      scrollbar-width: none;
    }
    .dj-scroll::-webkit-scrollbar {
      display: none;
    }
    /* drop the status column; keep ≥44-ish tappable rows */
    .dj-queue .dj-head,
    .dj-queue .dj-track {
      grid-template-columns: 26px 34px minmax(0, 1fr) 78px;
      gap: 10px;
    }
    .dj-queue .dj-col-status {
      display: none;
    }
    .dj-used ul {
      min-width: 200px;
    }
    .dj-contact-stats .stat {
      min-width: 100%;
    }
  }
</style>
