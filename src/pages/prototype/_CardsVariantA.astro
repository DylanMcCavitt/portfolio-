---
/**
 * PROTOTYPE — Cards variant A · "Screenshot" (image-led, the work IS the identity).
 *
 * No 2-letter tile, no glyph: each project's first real screenshot is the card's
 * visual. Wide shots fill a 16:10 frame (object-fit: cover, anchored to the top
 * so dashboard headers stay visible); portrait phone captures are letterboxed
 * (object-fit: contain) onto a blurred, darkened mat of themselves so the frame
 * never shows flat black bars. Projects with no captured image (e.g. `hood`)
 * fall back to a tasteful hue cover built from `project.hue` with the title
 * faintly overlaid — never a broken <img>. A 2px hue accent bar sits under the
 * media and the card gains a hue ring on hover. Consumed by
 * `/prototype/cards?variant=A`; scoped styles only.
 */
import type { Project } from '../../data/catalog';
import { isImageShot } from '../../data/catalog';

export interface Props {
  projects: Project[];
}
const { projects } = Astro.props;

// Resolve each project's lead visual once: its first real screenshot (or null →
// hue cover). `phone` drives the letterbox-on-blurred-mat treatment.
const cards = projects.map((project) => ({
  project,
  img: project.shots.find(isImageShot) ?? null,
}));
---

<section class="cards-a">
  <p class="proto-label">Variant A — Screenshot · the real work is the card</p>

  <div class="grid">
    {
      cards.map(({ project, img }) => (
        <a class="card" href={`/prototype/project/${project.id}`} style={`--hue:${project.hue}`}>
          <div class:list={['media', img ? (img.phone ? 'is-phone' : 'is-wide') : 'is-cover']}>
            {img ? (
              <Fragment>
                {img.phone && (
                  <img
                    class="mat"
                    src={img.img}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    decoding="async"
                    width="900"
                    height="1600"
                  />
                )}
                <img
                  class="shot"
                  src={img.img}
                  alt={img.cap || `${project.title} screenshot`}
                  loading="lazy"
                  decoding="async"
                  width={img.phone ? 900 : 1600}
                  height={img.phone ? 1600 : 1000}
                />
              </Fragment>
            ) : (
              <div class="cover" aria-hidden="true">
                <span class="cover-area">{project.area}</span>
                <span class="cover-title">{project.title}</span>
              </div>
            )}
            <span class="activity">{project.activity}</span>
          </div>

          <div class="body">
            <h3 class="title">{project.title}</h3>
            <div class="meta">
              <span class="where">
                {project.area} · {project.year}
              </span>
              <span class:list={['badge', project.status[0]]}>{project.status[1]}</span>
            </div>
            <p class="line">{project.line}</p>
          </div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .cards-a {
    max-width: 1160px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .proto-label {
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
    margin-bottom: 22px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 22px;
  }

  /* ---- card shell ---- */
  .card {
    display: flex;
    flex-direction: column;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    overflow: hidden;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in oklab, var(--hue) 55%, var(--pl-line));
    box-shadow:
      0 16px 34px -14px rgba(0, 0, 0, 0.65),
      0 0 0 1px color-mix(in oklab, var(--hue) 38%, transparent);
  }
  .card:focus-visible {
    outline: 2px solid var(--pl-focus);
    outline-offset: 2px;
  }

  /* ---- media frame: 16:10, hue accent bar under it ---- */
  .media {
    position: relative;
    aspect-ratio: 16 / 10;
    background: var(--pl-tile);
    overflow: hidden;
    border-bottom: 2px solid var(--hue);
  }
  .media .shot,
  .media .mat {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* wide screenshots fill the frame, anchored top so headers stay in view */
  .media.is-wide .shot {
    object-fit: cover;
    object-position: center top;
    transition: transform 0.35s ease;
  }
  .card:hover .media.is-wide .shot {
    transform: scale(1.04);
  }

  /* portrait phone shots: contained foreground over a blurred mat of themselves */
  .media.is-phone .mat {
    object-fit: cover;
    transform: scale(1.3);
    filter: blur(26px) saturate(1.15) brightness(0.4);
  }
  .media.is-phone .shot {
    object-fit: contain;
    padding: 14px 0;
    z-index: 1;
  }

  /* ---- hue cover fallback (no captured image) ---- */
  .cover {
    position: absolute;
    inset: 0;
    padding: 16px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background:
      radial-gradient(
        130% 120% at 18% 0%,
        color-mix(in oklab, var(--hue) 42%, transparent),
        transparent 58%
      ),
      linear-gradient(
        155deg,
        color-mix(in oklab, var(--hue) 20%, var(--pl-tile)) 0%,
        var(--pl-tile) 70%
      );
  }
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      color-mix(in oklab, var(--hue) 30%, transparent) 1px,
      transparent 1.5px
    );
    background-size: 20px 20px;
    opacity: 0.4;
    -webkit-mask-image: linear-gradient(180deg, #000, transparent 75%);
    mask-image: linear-gradient(180deg, #000, transparent 75%);
  }
  .cover-area {
    position: absolute;
    top: 14px;
    left: 16px;
    z-index: 1;
    font-family: var(--pl-mono);
    font-size: 10.5px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--hue) 55%, var(--pl-text));
  }
  .cover-title {
    position: relative;
    z-index: 1;
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.04;
    color: color-mix(in oklab, var(--hue) 35%, #ffffff);
    opacity: 0.22;
  }

  /* ---- floating activity chip over the visual ---- */
  .activity {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 3;
    font-family: var(--pl-mono);
    font-size: 10.5px;
    letter-spacing: 0.3px;
    color: var(--pl-text);
    background: rgba(12, 13, 17, 0.62);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 3px 8px;
    border-radius: 99px;
    white-space: nowrap;
  }

  /* ---- body ---- */
  .body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 16px 16px;
  }
  .title {
    font-size: 15.5px;
    font-weight: 700;
    letter-spacing: -0.2px;
    color: var(--pl-text);
  }
  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-wrap: wrap;
  }
  .where {
    font-family: var(--pl-mono);
    font-size: 11.5px;
    color: var(--pl-dim);
  }
  .line {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--pl-faint);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- mobile: single column ---- */
  @media (max-width: 820px) {
    .cards-a {
      padding: 28px 16px 64px;
    }
    .grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .media.is-wide .shot {
      transition: none;
    }
    .card:hover {
      transform: none;
    }
    .card:hover .media.is-wide .shot {
      transform: none;
    }
  }
</style>
