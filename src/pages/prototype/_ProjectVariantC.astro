---
/**
 * PROTOTYPE — throwaway, do not ship. Project-detail variant C: "Gallery".
 *
 * Screenshot-led, visual-first. The work itself leads: a split hero (text on
 * one side, the first screenshot large on the other) flows straight into a
 * dominant Screenshots gallery as the centerpiece, with all the written
 * details (Metrics / About / Highlights / Details) kept compact below it, and
 * image-forward "More projects" cards at the foot. No player/Spotify chrome.
 *
 * Structurally distinct from A (centered editorial prose) and B (two-column
 * spec rail): here imagery dominates and copy is secondary. Receives the
 * showcased project + related list as props; the route owns the <head>, the
 * base reset/palette, and the variant switcher. Lightbox ids are namespaced
 * (`c-shot-N`) so they never collide with the sibling variants rendered in the
 * same document. Pure CSS, zero client JS.
 */
import { isImageShot, type Project } from '../../data/catalog';

export interface Props {
  project: Project;
  related: Project[];
}
const { project, related } = Astro.props;

const heroShot = project.shots[0];
const galleryShots = project.shots.slice(1);

/** Phone shots (real 9:16 captures or `kind: 'phone'` skeletons) get the
 * narrow frame; everything else gets the wide 3:2 frame. */
const isPhone = (shot: Project['shots'][number]) =>
  isImageShot(shot) ? shot.phone === true : shot.kind === 'phone';

/** Intrinsic dimensions so images reserve layout (zero CLS). */
const dims = (phone: boolean) => (phone ? { w: 360, h: 640 } : { w: 1200, h: 800 });

/** Plain-language label for a skeleton placeholder kind. */
const KIND_LABEL: Record<string, string> = {
  chart: 'Chart',
  dash: 'Dashboard',
  list: 'List',
  code: 'Code',
  phone: 'Phone screen',
};
---

<div class="gp" style={`--acc:${project.hue}`}>
  <header class="topbar">
    <a class="back" href="/library">← Back</a>
  </header>

  <main class="wrap">
    {/* ---- split hero: text + first screenshot ---- */}
    <section class="hero">
      <div class="hero-text">
        <span class="eyebrow">{project.area} · {project.year}</span>
        <h1>{project.title}</h1>
        <p class="tagline">{project.line}</p>
        <div class="hero-meta">
          <span class:list={['badge', project.status[0]]}>{project.status[1]}</span>
          <span class="activity">{project.activity}</span>
        </div>
        {
          project.links.length > 0 && (
            <div class="cta">
              {project.links.map(([label, url], i) => (
                <a
                  class:list={['btn', i === 0 ? 'primary' : 'ghost']}
                  href={url}
                  target="_blank"
                  rel="noopener"
                >
                  {label}
                </a>
              ))}
            </div>
          )
        }
      </div>

      <div class="hero-media">
        {
          heroShot &&
            (isImageShot(heroShot) ? (
              <a
                class:list={['frame', isPhone(heroShot) ? 'phone' : 'wide']}
                href="#c-shot-0"
                aria-label={`Expand screenshot: ${heroShot.cap}`}
              >
                <img
                  src={heroShot.img}
                  alt={heroShot.cap}
                  width={dims(isPhone(heroShot)).w}
                  height={dims(isPhone(heroShot)).h}
                  loading="eager"
                  decoding="async"
                />
              </a>
            ) : (
              <div class:list={['frame', 'skel', isPhone(heroShot) ? 'phone' : 'wide']}>
                <span class="skel-kind">{KIND_LABEL[heroShot.kind] ?? 'Preview'}</span>
                <span class="skel-cap">{heroShot.cap}</span>
              </div>
            ))
        }
      </div>
    </section>

    {/* ---- the main event: screenshot gallery ---- */}
    {
      galleryShots.length > 0 && (
        <section class="gallery-sec">
          <h2 class="sec-head">Screenshots</h2>
          <div class="gallery">
            {galleryShots.map((shot, gi) => {
              const idx = gi + 1;
              const phone = isPhone(shot);
              return (
                <figure class:list={['gtile', phone ? 'phone' : 'wide']}>
                  {isImageShot(shot) ? (
                    <a
                      class="shot-link"
                      href={`#c-shot-${idx}`}
                      aria-label={`Expand screenshot: ${shot.cap}`}
                    >
                      <img
                        src={shot.img}
                        alt={shot.cap}
                        width={dims(phone).w}
                        height={dims(phone).h}
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  ) : (
                    <div class="skel" aria-hidden="true">
                      <span class="skel-kind">{KIND_LABEL[shot.kind] ?? 'Preview'}</span>
                    </div>
                  )}
                  <figcaption>{shot.cap}</figcaption>
                </figure>
              );
            })}
          </div>
        </section>
      )
    }

    {/* ---- compact details band (lighter than the gallery) ---- */}
    <section class="band">
      {
        project.metrics.length > 0 && (
          <div class="metrics">
            {project.metrics.map(([value, label]) => (
              <div class="metric">
                <b>{value}</b>
                <span>{label}</span>
              </div>
            ))}
          </div>
        )
      }

      <div class="band-grid">
        <div class="col-about">
          <h3 class="sub-head">About</h3>
          <div class="prose">
            {project.about.map((para) => <p>{para}</p>)}
          </div>
        </div>

        <div class="col-side">
          {
            project.notes.length > 0 && (
              <div class="block">
                <h3 class="sub-head">Highlights</h3>
                <ul class="highlights">
                  {project.notes.map((note) => <li>{note}</li>)}
                </ul>
              </div>
            )
          }
          {
            project.stack.length > 0 && (
              <div class="block">
                <h3 class="sub-head">Details</h3>
                <dl class="specs">
                  {project.stack.map(([label, value]) => (
                    <div class="spec">
                      <dt>{label}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }
        </div>
      </div>
    </section>

    {/* ---- more projects: image-forward cards ---- */}
    {
      related.length > 0 && (
        <section class="more">
          <h2 class="sec-head">More projects</h2>
          <div class="more-grid">
            {related.map((r) => (
              <a class="rcard" href={`/prototype/project/${r.id}`} style={`--rh:${r.hue}`}>
                <span class="rsym">{r.sym}</span>
                <span class="rinfo">
                  <b>{r.title}</b>
                  <span class="rmeta">{r.area} · {r.year}</span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>

  {/* Zero-JS lightbox: each real screenshot links to `#c-shot-N`; `:target`
      reveals the matching fixed overlay. The overlay is itself the close link
      (`#!` matches nothing, so :target clears with no scroll jump). */}
  {
    project.shots.map(
      (shot, i) =>
        isImageShot(shot) && (
          <a class="lightbox" id={`c-shot-${i}`} href="#!" aria-label="Close screenshot">
            <img src={shot.img} alt={shot.cap} loading="lazy" decoding="async" />
            <span class="lb-cap">{shot.cap}</span>
          </a>
        ),
    )
  }
</div>

<style>
  .gp {
    --maxw: 1180px;
    --gutter: 30px;
    color: var(--pl-text);
    font-family: var(--pl-sans);
    padding-bottom: 88px;
  }

  /* ---- minimal top bar ---- */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    padding: 14px var(--gutter);
    background: color-mix(in srgb, var(--pl-bg) 86%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--pl-line);
  }
  .back {
    font-family: var(--pl-mono);
    font-size: 12px;
    letter-spacing: 0.3px;
    color: var(--pl-dim);
    padding: 5px 2px;
    transition: color 0.15s ease;
  }
  .back:hover {
    color: var(--pl-text);
  }

  .wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* ---- split hero ---- */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 44px;
    align-items: center;
    padding: 52px 0 8px;
  }
  .hero-text {
    min-width: 0;
  }
  .eyebrow {
    display: inline-block;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--acc);
  }
  .hero-text h1 {
    margin: 12px 0 0;
    font-size: clamp(30px, 4.4vw, 46px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.04;
  }
  .tagline {
    margin: 16px 0 0;
    max-width: 46ch;
    font-size: 16px;
    line-height: 1.55;
    color: var(--pl-dim);
  }
  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
  }
  .activity {
    font-family: var(--pl-mono);
    font-size: 12px;
    color: var(--pl-faint);
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }
  .btn {
    font-size: 13px;
    font-weight: 600;
    padding: 10px 18px;
    border-radius: 8px;
    border: 1px solid transparent;
    transition:
      transform 0.12s ease,
      background 0.15s ease,
      border-color 0.15s ease;
  }
  .btn.primary {
    background: var(--acc);
    color: #0e1014;
  }
  .btn.ghost {
    border-color: var(--pl-line);
    color: var(--pl-text);
  }
  .btn:hover {
    transform: translateY(-1px);
  }
  .btn.ghost:hover {
    border-color: color-mix(in srgb, var(--acc) 50%, var(--pl-line));
  }

  /* ---- hero media frame ---- */
  .hero-media {
    min-width: 0;
    display: flex;
    justify-content: center;
  }
  .frame {
    display: block;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--pl-bg);
    border: 1px solid var(--pl-line);
    box-shadow:
      0 24px 60px -28px rgb(0 0 0 / 0.7),
      0 0 0 1px color-mix(in srgb, var(--acc) 22%, transparent);
  }
  a.frame {
    cursor: zoom-in;
  }
  .frame.wide {
    aspect-ratio: 3 / 2;
  }
  .frame.phone {
    aspect-ratio: 9 / 16;
    width: min(310px, 100%);
  }
  .frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }
  .frame.phone img {
    object-fit: cover;
  }

  /* skeleton frame (hero) */
  .frame.skel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 28px;
    text-align: center;
    background:
      radial-gradient(
        130% 90% at 50% 0%,
        color-mix(in srgb, var(--acc) 16%, transparent),
        transparent 70%
      ),
      var(--pl-tile);
    border-color: color-mix(in srgb, var(--acc) 28%, var(--pl-line));
  }
  .skel-kind {
    font-family: var(--pl-mono);
    font-size: 12px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--acc) 72%, var(--pl-text));
  }
  .skel-cap {
    font-size: 12.5px;
    color: var(--pl-dim);
    max-width: 30ch;
  }

  /* ---- gallery (centerpiece) ---- */
  .gallery-sec {
    margin-top: 60px;
  }
  .sec-head {
    font-size: 13px;
    font-weight: 700;
    font-family: var(--pl-mono);
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--pl-text);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .sec-head::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--pl-line);
  }
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(248px, 1fr));
    grid-auto-flow: dense;
    gap: 22px;
    margin-top: 24px;
  }
  .gtile {
    margin: 0;
    min-width: 0;
  }
  .gtile.wide {
    grid-column: span 2;
  }
  .shot-link,
  .gtile .skel {
    display: block;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--pl-line);
    background: var(--pl-bg);
  }
  .shot-link {
    cursor: zoom-in;
  }
  .gtile.wide .shot-link {
    aspect-ratio: 3 / 2;
  }
  .gtile.phone .shot-link {
    aspect-ratio: 9 / 16;
  }
  .shot-link img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: top;
    transition: transform 0.3s ease;
  }
  .gtile.phone .shot-link img {
    object-fit: cover;
  }
  .shot-link:hover img {
    transform: scale(1.025);
  }
  .gtile .skel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 20px;
    text-align: center;
    background:
      radial-gradient(
        130% 100% at 50% 0%,
        color-mix(in srgb, var(--acc) 16%, transparent),
        transparent 72%
      ),
      var(--pl-tile);
    border-color: color-mix(in srgb, var(--acc) 26%, var(--pl-line));
  }
  .gtile.wide .skel {
    aspect-ratio: 3 / 2;
  }
  .gtile.phone .skel {
    aspect-ratio: 9 / 16;
  }
  figcaption {
    margin-top: 10px;
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--pl-dim);
  }

  /* ---- compact details band ---- */
  .band {
    margin-top: 66px;
  }
  .metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .metric {
    flex: 1 1 150px;
    min-width: 0;
    padding: 14px 16px;
    border: 1px solid var(--pl-line);
    border-radius: 10px;
    background: color-mix(in srgb, var(--pl-panel) 60%, transparent);
  }
  .metric b {
    display: block;
    font-family: var(--pl-mono);
    font-size: 19px;
    font-weight: 600;
    color: var(--pl-text);
  }
  .metric span {
    display: block;
    margin-top: 4px;
    font-size: 11.5px;
    line-height: 1.4;
    color: var(--pl-faint);
  }
  .band-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
    gap: 48px;
    margin-top: 36px;
  }
  .sub-head {
    font-size: 11px;
    font-weight: 600;
    font-family: var(--pl-mono);
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
    margin-bottom: 14px;
  }
  .prose {
    max-width: 64ch;
  }
  .prose p {
    font-size: 14.5px;
    line-height: 1.68;
    color: color-mix(in srgb, var(--pl-text) 88%, var(--pl-dim));
  }
  .prose p + p {
    margin-top: 14px;
  }
  .block + .block {
    margin-top: 30px;
  }
  .highlights {
    list-style: none;
  }
  .highlights li {
    position: relative;
    padding-left: 20px;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--pl-dim);
  }
  .highlights li + li {
    margin-top: 11px;
  }
  .highlights li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--acc);
  }
  .specs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .spec {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 9px 0;
    border-bottom: 1px solid var(--pl-line);
  }
  .spec:first-child {
    border-top: 1px solid var(--pl-line);
  }
  .spec dt {
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .spec dd {
    font-size: 13px;
    color: var(--pl-text);
    text-align: right;
  }

  /* ---- more projects (image-forward cards) ---- */
  .more {
    margin-top: 66px;
  }
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
    margin-top: 24px;
  }
  .rcard {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px;
    border: 1px solid var(--pl-line);
    border-radius: 12px;
    background: var(--pl-panel);
    transition:
      transform 0.12s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .rcard:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--rh) 45%, var(--pl-line));
    background: var(--pl-panel-hi);
  }
  .rsym {
    flex: 0 0 auto;
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border-radius: 10px;
    font-family: var(--pl-mono);
    font-size: 16px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--rh);
    background: color-mix(in srgb, var(--rh) 16%, var(--pl-tile));
    border: 1px solid color-mix(in srgb, var(--rh) 32%, var(--pl-tile-line));
  }
  .rinfo {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rinfo b {
    font-size: 14px;
    font-weight: 600;
    color: var(--pl-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rmeta {
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }

  /* ---- zero-JS :target lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: none;
    place-items: center;
    align-content: center;
    gap: 10px;
    padding: 4vh 4vw;
    background: rgb(0 0 0 / 0.86);
    cursor: zoom-out;
  }
  .lightbox:target {
    display: grid;
  }
  .lightbox img {
    max-width: 100%;
    max-height: 84vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--pl-line);
  }
  .lb-cap {
    font-size: 12.5px;
    color: #e3e6ec;
  }

  /* ---- mobile: single column, stack hero (text then image) ---- */
  @media (max-width: 820px) {
    .gp {
      --gutter: 18px;
    }
    .hero {
      grid-template-columns: 1fr;
      gap: 26px;
      padding: 32px 0 4px;
    }
    .hero-media {
      order: 2;
    }
    .gallery {
      grid-template-columns: 1fr;
    }
    .gtile.wide,
    .gtile.phone {
      grid-column: span 1;
    }
    .gtile.phone .shot-link,
    .gtile.phone .skel,
    .frame.phone {
      max-width: 280px;
      margin-inline: auto;
    }
    .band-grid {
      grid-template-columns: 1fr;
      gap: 34px;
    }
  }
</style>
