---
/**
 * PROTOTYPE variant B — "Spec sheet".
 *
 * A structured two-column project page, the way a GitHub repo page or a product
 * spec reads: a slim back bar, a compact full-width title header, then a STICKY
 * left meta rail (the at-a-glance facts) beside a scrolling right content column
 * (About / Highlights / Screenshots), with a full-width "More projects" row
 * below. Deliberately different from the centered editorial variant.
 *
 * Zero client JS: the page scrolls as a normal document, the rail is pure CSS
 * `position: sticky`, and screenshots enlarge via a `:target` lightbox (ids are
 * `shotB-*`-prefixed so they never collide with the other variants rendered in
 * the same DOM). No Spotify-isms — no play button, seek bar, equalizer, or
 * player chrome. Tokens come from the global `--pl-*` palette; `project.hue`
 * is threaded in as the per-page accent.
 */
import { isImageShot, type Project } from '../../data/catalog';

export interface Props {
  project: Project;
  related: Project[];
}
const { project, related } = Astro.props;

// Reserve layout for each shot variant (wide ~3:2, phone 9:16) so images don't
// shift as they decode; the CSS frame letterboxes whatever the real ratio is.
const WIDE = { w: 1200, h: 800 };
const PHONE = { w: 1080, h: 1920 };
const isPhone = (shot: Project['shots'][number]) =>
  isImageShot(shot) ? shot.phone === true : shot.kind === 'phone';

const SK_LABEL: Record<string, string> = {
  chart: 'Chart',
  dash: 'Dashboard',
  list: 'List',
  code: 'Code',
  phone: 'Mobile',
};
---

<article class="spec" style={`--accent:${project.hue}`}>
  <nav class="topbar">
    <div class="bar-inner">
      <a class="back" href="/library"><span aria-hidden="true">←</span> Library</a>
    </div>
  </nav>

  <header class="pagehead">
    <h1>{project.title}</h1>
    <p class="tagline">{project.line}</p>
    <span class="accent-rule" aria-hidden="true"></span>
  </header>

  <div class="layout">
    {/* ---- LEFT: sticky at-a-glance meta rail ---- */}
    <aside class="rail">
      <div class="panel">
        <div class="facts">
          <span class:list={['badge', project.status[0]]}>{project.status[1]}</span>
          <dl class="factlist">
            <div>
              <dt>Area</dt>
              <dd>{project.area} · {project.year}</dd>
            </div>
            <div>
              <dt>Activity</dt>
              <dd class="mono">{project.activity}</dd>
            </div>
          </dl>
        </div>

        {
          project.metrics.length > 0 && (
            <section class="block">
              <h2>Metrics</h2>
              <ul class="metrics">
                {project.metrics.map(([value, label]) => (
                  <li>
                    <b>{value}</b>
                    <span>{label}</span>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        {
          project.stack.length > 0 && (
            <section class="block">
              <h2>Details</h2>
              <dl class="details">
                {project.stack.map(([label, value]) => (
                  <div>
                    <dt>{label}</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>
            </section>
          )
        }
      </div>

      {
        project.links.length > 0 && (
          <div class="links">
            {project.links.map(([label, url], i) => (
              <a
                class:list={['lnk', i === 0 ? 'primary' : 'outline']}
                href={url}
                target="_blank"
                rel="noopener"
              >
                {label}
              </a>
            ))}
          </div>
        )
      }
    </aside>

    {/* ---- RIGHT: scrolling content ---- */}
    <main class="content">
      {
        project.about.length > 0 && (
          <section class="sec">
            <h2>About</h2>
            <div class="prose">
              {project.about.map((para) => (
                <p>{para}</p>
              ))}
            </div>
          </section>
        )
      }

      {
        project.notes.length > 0 && (
          <section class="sec">
            <h2>Highlights</h2>
            <ul class="highlights">
              {project.notes.map((note) => (
                <li>{note}</li>
              ))}
            </ul>
          </section>
        )
      }

      {
        project.shots.length > 0 && (
          <section class="sec">
            <h2>Screenshots</h2>
            <div class="shots">
              {project.shots.map((shot, i) => {
                const phone = isPhone(shot);
                const dims = phone ? PHONE : WIDE;
                if (isImageShot(shot)) {
                  return (
                    <figure class:list={['shot', { phone }]}>
                      <a
                        class="frame"
                        href={`#shotB-${i}`}
                        aria-label={`Enlarge screenshot: ${shot.cap}`}
                      >
                        <img
                          src={shot.img}
                          alt={shot.cap}
                          width={dims.w}
                          height={dims.h}
                          loading="lazy"
                          decoding="async"
                        />
                      </a>
                      <figcaption>{shot.cap}</figcaption>
                    </figure>
                  );
                }
                return (
                  <figure class:list={['shot', { phone }]}>
                    <div class="frame sk" data-kind={shot.kind}>
                      <span class="sk-kind">{SK_LABEL[shot.kind] ?? shot.kind}</span>
                    </div>
                    <figcaption>{shot.cap}</figcaption>
                  </figure>
                );
              })}
            </div>
          </section>
        )
      }
    </main>
  </div>

  {/* Zero-JS lightbox: a real screenshot links to `#shotB-N`; `:target` reveals
      the matching fixed overlay. The overlay is itself the close link (`#!`
      matches nothing, so the page returns to where it was). */}
  {
    project.shots.map(
      (shot, i) =>
        isImageShot(shot) && (
          <a class="lightbox" id={`shotB-${i}`} href="#!" aria-label="Close screenshot">
            <img src={shot.img} alt={shot.cap} loading="lazy" decoding="async" />
            <span class="lb-cap">{shot.cap}</span>
          </a>
        ),
    )
  }

  {
    related.length > 0 && (
      <section class="more">
        <h2>More projects</h2>
        <div class="cards">
          {related.map((r) => (
            <a class="card" href={`/prototype/project/${r.id}`} style={`--accent:${r.hue}`}>
              <span class="strip" aria-hidden="true" />
              <span class="card-title">{r.title}</span>
              <span class="card-line">{r.line}</span>
              <span class="card-foot">
                <span class:list={['badge', r.status[0]]}>{r.status[1]}</span>
                <span class="card-area">{r.area}</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    )
  }
</article>

<style>
  .spec {
    --gutter: 40px;
    --maxw: 1120px;
    display: block;
    width: 100%;
    min-height: 100dvh;
    color: var(--pl-text);
    font-family: var(--pl-sans);
    font-size: 14px;
  }
  .mono {
    font-family: var(--pl-mono);
  }

  /* ---- slim top bar ---- */
  .topbar {
    border-bottom: 1px solid var(--pl-line);
    background: var(--pl-side);
  }
  .bar-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 12px var(--gutter);
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.2px;
    color: var(--pl-dim);
    transition: color 0.15s ease;
  }
  .back:hover {
    color: var(--pl-text);
  }
  .back span {
    color: var(--accent);
    font-size: 15px;
  }

  /* ---- compact title header ---- */
  .pagehead {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 40px var(--gutter) 28px;
  }
  .pagehead h1 {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.12;
  }
  .tagline {
    margin-top: 12px;
    max-width: 70ch;
    font-size: 16px;
    line-height: 1.5;
    color: var(--pl-dim);
  }
  .accent-rule {
    display: block;
    margin-top: 20px;
    width: 56px;
    height: 3px;
    border-radius: 99px;
    background: var(--accent);
  }

  /* ---- two-column layout ---- */
  .layout {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--gutter) 16px;
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 44px;
    align-items: start;
  }

  /* ---- left rail (sticky) ---- */
  .rail {
    position: sticky;
    top: 24px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .panel {
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    overflow: hidden;
  }
  .facts {
    padding: 18px 18px 16px;
  }
  .facts .badge {
    display: inline-block;
  }
  .factlist {
    margin-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .factlist dt {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .factlist dd {
    margin-top: 3px;
    font-size: 13.5px;
    color: var(--pl-text);
  }
  .factlist dd.mono {
    font-family: var(--pl-mono);
    font-size: 12.5px;
    color: var(--pl-dim);
  }

  .block {
    padding: 16px 18px;
    border-top: 1px solid var(--pl-line);
  }
  .block h2 {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--pl-faint);
    margin-bottom: 12px;
  }

  /* metrics — value over label, comfortable vertical list */
  .metrics {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .metrics li {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .metrics b {
    font-family: var(--pl-mono);
    font-size: 17px;
    font-weight: 500;
    line-height: 1.1;
    color: var(--pl-text);
  }
  .metrics span {
    font-size: 11.5px;
    color: var(--pl-faint);
    line-height: 1.35;
  }

  /* details — label/value rows with hairline separators */
  .details {
    display: flex;
    flex-direction: column;
  }
  .details > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 14px;
    padding: 9px 0;
    border-bottom: 1px solid var(--pl-line);
  }
  .details > div:first-child {
    padding-top: 0;
  }
  .details > div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }
  .details dt {
    font-size: 11px;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
    flex-shrink: 0;
  }
  .details dd {
    font-family: var(--pl-mono);
    font-size: 12.5px;
    color: var(--pl-text);
    text-align: right;
  }

  /* link buttons — primary (accent) + outline, full width */
  .links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .lnk {
    display: block;
    width: 100%;
    padding: 11px 14px;
    border-radius: 10px;
    text-align: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.2px;
    transition:
      transform 0.12s ease,
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .lnk:active {
    transform: translateY(1px);
  }
  .lnk.primary {
    background: var(--accent);
    color: var(--pl-bg);
  }
  .lnk.primary:hover {
    filter: brightness(1.08);
  }
  .lnk.outline {
    border: 1px solid var(--pl-line);
    color: var(--pl-text);
  }
  .lnk.outline:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--pl-panel-hi);
  }

  /* ---- right content column ---- */
  .content {
    min-width: 0;
    padding-top: 4px;
  }
  .sec {
    margin-bottom: 36px;
  }
  .sec:last-child {
    margin-bottom: 0;
  }
  .sec > h2 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-dim);
    padding-bottom: 10px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--pl-line);
  }

  .prose p {
    max-width: 68ch;
    font-size: 15px;
    line-height: 1.68;
    color: var(--pl-text);
  }
  .prose p + p {
    margin-top: 16px;
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 68ch;
  }
  .highlights li {
    position: relative;
    padding-left: 22px;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--pl-text);
  }
  .highlights li::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 9px;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--accent);
  }

  /* ---- screenshots: stacked, full-width in the content column ---- */
  .shots {
    display: flex;
    flex-direction: column;
    gap: 26px;
  }
  .shot {
    margin: 0;
  }
  .frame {
    display: block;
    aspect-ratio: 3 / 2;
    background: var(--pl-tile);
    border: 1px solid var(--pl-tile-line);
    border-radius: 12px;
    overflow: hidden;
  }
  a.frame {
    cursor: zoom-in;
    transition: border-color 0.15s ease;
  }
  a.frame:hover {
    border-color: var(--accent);
  }
  .frame img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .shot.phone .frame {
    aspect-ratio: 9 / 16;
    max-width: 280px;
  }
  .shot.phone .frame img {
    object-fit: cover;
  }
  figcaption {
    margin-top: 10px;
    font-size: 12.5px;
    color: var(--pl-faint);
    line-height: 1.4;
  }

  /* skeleton placeholder — tinted with the project hue, kind + caption */
  .frame.sk {
    position: relative;
    display: grid;
    place-items: center;
    background:
      radial-gradient(120% 120% at 50% 0%, color-mix(in srgb, var(--accent) 22%, transparent), transparent 70%),
      var(--pl-tile);
    border-style: dashed;
    border-color: color-mix(in srgb, var(--accent) 38%, var(--pl-tile-line));
  }
  .sk-kind {
    font-family: var(--pl-mono);
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 78%, var(--pl-text));
    padding: 6px 14px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--pl-tile-line));
    border-radius: 99px;
    background: color-mix(in srgb, var(--pl-bg) 55%, transparent);
  }

  /* ---- :target lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: none;
    place-items: center;
    flex-direction: column;
    gap: 14px;
    padding: 5vmin;
    background: rgba(9, 10, 13, 0.92);
    cursor: zoom-out;
  }
  .lightbox:target {
    display: grid;
  }
  .lightbox img {
    max-width: 92vw;
    max-height: 82vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
  }
  .lb-cap {
    font-size: 13px;
    color: var(--pl-dim);
    text-align: center;
  }

  /* ---- more projects (full-width row) ---- */
  .more {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 28px var(--gutter) 64px;
    border-top: 1px solid var(--pl-line);
    margin-top: 28px;
  }
  .more > h2 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-dim);
    margin-bottom: 18px;
  }
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px 16px 14px;
    background: var(--pl-side);
    border: 1px solid var(--pl-line);
    border-radius: 12px;
    overflow: hidden;
    transition:
      border-color 0.15s ease,
      transform 0.12s ease,
      background 0.15s ease;
  }
  .card:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--pl-line));
    background: var(--pl-panel);
    transform: translateY(-2px);
  }
  .card .strip {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
  }
  .card-title {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--pl-text);
  }
  .card-line {
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--pl-dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    margin-top: auto;
    padding-top: 6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .card-area {
    font-size: 11px;
    color: var(--pl-faint);
  }

  /* ---- mobile: single column, rail on top (not sticky) ---- */
  @media (max-width: 820px) {
    .spec {
      --gutter: 20px;
    }
    .layout {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .rail {
      position: static;
      top: auto;
    }
    .pagehead {
      padding-top: 30px;
    }
    .shot.phone .frame {
      max-width: 240px;
    }
  }
</style>
