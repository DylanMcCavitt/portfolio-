---
/**
 * PROTOTYPE — throwaway, do not ship. One route, three variant dimensions:
 *
 *   ?home=A|B|C    landing structure  (A now-playing · B artist profile · C billboard)
 *   ?cover=A|B|C|D album-art style    (A accent bar · B gradient · C framed · D vinyl)
 *
 * (The mobile dimension is decided — tab bar, graduated into the production
 * shell/`player.css` on 2026-06-12 — so it's no longer a variant here.)
 *
 * A floating panel (bottom-center) cycles variants and exposes fine-tune knobs
 * (cover radius, tint, gradient, title weight/tracking, row density, …). All
 * state lives in the URL, so any combination is shareable. The "phone" button
 * previews the page in a 390px iframe so the <820px media queries actually
 * fire without devtools.
 *
 * Sub-shape B (new page) on purpose: the mobile dimension swaps the app shell
 * itself, which the production layout can't host per-variant. Real data
 * (catalog), real chrome (Sidebar/PlayerBar), real tokens (player.css) — only
 * the view markup here is prototype-local. Delete this folder when a winner
 * is picked; see _NOTES.md.
 */
import Sidebar from '../../components/player/Sidebar.astro';
import PlayerBar from '../../components/player/PlayerBar.astro';
import TabBar from '../../components/player/TabBar.astro';
import ProtoTracklist from './_ProtoTracklist.astro';
import {
  AREA_PLAYLISTS,
  CATALOG,
  filterCatalog,
  playlistCount,
  playlistSlug,
} from '../../data/catalog';
import '../../styles/player.css';

const now = CATALOG[0];

const CONTACT = {
  github: 'https://github.com/DylanMcCavitt',
  resume: 'https://dylanmccavitt.xyz/resume.pdf',
};

/** Sidebar-style labels for area playlists. */
const PLAYLIST_LABEL: Partial<Record<string, string>> = {
  School: 'School · Stevens',
  Research: 'Research & retired',
};

/** 2-letter playlist sym, same derivation as LibraryView's playlist hero. */
const sym2 = (label: string) => {
  const w = label.split(/\s+/).filter((x) => /^[a-z0-9]/i.test(x));
  return (w.length >= 2 ? w[0][0] + w[1][0] : label.slice(0, 2)).toLowerCase();
};

/** Featured picks for home C's pinned grid: wip/money first, then the rest. */
const featured = [
  ...CATALOG.filter((p) => p.wip || p.money),
  ...CATALOG.filter((p) => !(p.wip || p.money)),
].slice(0, 4);

---

<!doctype html>
<!-- defaults = Dylan's picked baseline (2026-06-12): home B · cover C + knob URL -->
<html lang="en" data-home="B" data-cover="C" class="k-th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>PROTOTYPE — player UI variants</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Mono:wght@400;500&display=swap"
    />
    <script is:inline>
      // Apply URL state before first paint (variants → data-attrs, knobs → CSS vars).
      (() => {
        const q = new URLSearchParams(location.search);
        const d = document.documentElement;
        const DIMS = { home: 'ABC', cover: 'ABCD' };
        const DEF = { home: 'B', cover: 'C' };
        for (const k in DIMS) {
          const v = (q.get(k) || DEF[k]).toUpperCase();
          d.dataset[k] = DIMS[k].includes(v) ? v : DEF[k];
        }
        const KN = {
          radius: [0, 28, 12],
          glyph: [60, 160, 85],
          tint: [0, 60, 23],
          bar: [0, 8, 4],
          grad: [0, 90, 35],
          hero: [120, 220, 180],
          tw: [500, 900, 650],
          tt: [-2.5, 0.5, -1.2],
          den: [6, 16, 16],
        };
        for (const k in KN) {
          let v = parseFloat(q.get(k));
          if (Number.isNaN(v)) v = KN[k][2];
          v = Math.min(KN[k][1], Math.max(KN[k][0], v));
          d.style.setProperty('--k-' + k, String(v));
        }
        if (q.get('lc') === '1') d.classList.add('k-lc');
        if (q.get('th') === '0') d.classList.remove('k-th');
        if (q.get('embed') === '1') d.classList.add('k-embed');
      })();
    </script>
  </head>
  <body class="player-body">
    <div class="body">
      <nav class="sidebar-nav" aria-label="Primary">
        <Sidebar active="all" />
      </nav>

      <main class="main" id="main" tabindex="-1">
        <!-- ============ HOME A — current "now playing" hero ============ -->
        <div class="view proto-home" data-home-view="A">
          <div class="head">
            <div class="hero">
              <span class="art lg" style={`--a:${now.hue}`} aria-hidden="true">{now.sym}</span>
              <div class="info">
                <span class="kind">Now playing · {now.status[1]}</span>
                <h1>{now.title}</h1>
                <p>{now.about[0]}</p>
                <div class="meta">
                  <span class:list={['badge', now.status[0]]}>{now.status[1]}</span>
                  <span><b>{now.stack.map((s) => s[1]).slice(0, 2).join(' · ')}</b></span>
                </div>
              </div>
            </div>
          </div>
          <div class="actions">
            <a class="bigplay" href={`/projects/${now.id}`} title="open project"></a>
            <a class="act-link" href={CONTACT.github} target="_blank" rel="noopener">GitHub ↗</a>
            <a class="act-link" href={CONTACT.resume} target="_blank" rel="noopener">Resume ↗</a>
          </div>
          <div class="listwrap">
            <div class="sec-title">All work</div>
            <ProtoTracklist list={CATALOG} now={now} />
          </div>
        </div>

        <!-- ============ HOME B — artist profile ============ -->
        <div class="view proto-home" data-home-view="B">
          <div class="bhead" style={`--a:${now.hue}`}>
            <span class="bavatar" aria-hidden="true">DM</span>
            <div>
              <span class="kind">Software engineer · NYC</span>
              <h1 class="btitle">Dylan McCavitt</h1>
              <div class="bstats">
                <span><b>{CATALOG.length}</b> projects</span>
                <span><b>{playlistCount('wip')}</b> now building</span>
                <span><b>{AREA_PLAYLISTS.length}</b> playlists</span>
              </div>
            </div>
          </div>
          <div class="actions">
            <a class="bigplay" href={`/projects/${now.id}`} title="play the latest"></a>
            <a class="act-link" href="/journey">Resume</a>
            <a class="act-link" href={CONTACT.github} target="_blank" rel="noopener">GitHub ↗</a>
            <a class="act-link" href={CONTACT.resume} target="_blank" rel="noopener">Resume.pdf ↗</a>
          </div>
          <div class="listwrap">
            <div class="sec-title">Top tracks</div>
            <ProtoTracklist list={CATALOG.slice(0, 5)} now={now} />
            <div class="sec-title">Playlists</div>
            <div class="brail">
              {
                AREA_PLAYLISTS.map((a) => {
                  const label = PLAYLIST_LABEL[a] ?? a;
                  const hue = filterCatalog(a)[0]?.hue ?? '#8b7cf6';
                  return (
                    <a href={`/library/${playlistSlug(a)}`}>
                      <span class="art" style={`--a:${hue}`} aria-hidden="true">{sym2(label)}</span>
                      <b>{label}</b>
                      <small>{playlistCount(a)} {playlistCount(a) === 1 ? 'track' : 'tracks'}</small>
                    </a>
                  );
                })
              }
            </div>
            <div class="sec-title">All work</div>
            <ProtoTracklist list={CATALOG} now={now} />
          </div>
        </div>

        <!-- ============ HOME C — editorial billboard ============ -->
        <div class="view proto-home" data-home-view="C">
          <section class="bb" style={`--a:${now.hue}`}>
            <span class="kind">Featured · {now.status[1]}</span>
            <h1 class="bb-title">{now.title}</h1>
            <p>{now.line}. {now.about[0]}</p>
            <div class="bb-actions">
              <a class="bigplay" href={`/projects/${now.id}`} title="open project"></a>
              <a class="act-link" href={CONTACT.github} target="_blank" rel="noopener">GitHub ↗</a>
              <a class="act-link" href={CONTACT.resume} target="_blank" rel="noopener">Resume ↗</a>
            </div>
          </section>
          <div class="listwrap">
            <div class="sec-title">Pinned</div>
            <div class="cgrid">
              {
                featured.map((p) => (
                  <a class="ccard" href={`/projects/${p.id}`}>
                    <span class="art" style={`--a:${p.hue}`} aria-hidden="true">{p.sym}</span>
                    <b>{p.title}</b>
                    <small>{p.line}</small>
                    <span class="ccard-meta">
                      <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
                      <span class="len">{p.activity}</span>
                    </span>
                  </a>
                ))
              }
            </div>
            <div class="sec-title">All tracks</div>
            <ProtoTracklist list={CATALOG} now={now} />
          </div>
        </div>
      </main>
    </div>

    <PlayerBar now={now} />
    <TabBar />

    <!-- ============ prototype chrome (not part of the design) ============ -->
    <aside class="proto-panel" aria-label="Prototype controls">
      <div class="pp-row">
        <span class="pp-grp" data-dim="home">
          <span class="lbl">Home</span>
          <button type="button" data-prev aria-label="Previous home variant">‹</button>
          <span class="val"></span>
          <button type="button" data-next aria-label="Next home variant">›</button>
        </span>
        <span class="pp-grp" data-dim="cover">
          <span class="lbl">Cover</span>
          <button type="button" data-prev aria-label="Previous cover variant">‹</button>
          <span class="val"></span>
          <button type="button" data-next aria-label="Next cover variant">›</button>
        </span>
        <span class="pp-actions">
          <button type="button" data-knobs>knobs</button>
          <button type="button" data-phone>phone</button>
          <button type="button" data-copy>copy url</button>
          <button type="button" data-reset>reset</button>
        </span>
      </div>
      <div class="pp-knobs">
        <label class="pp-knob">cover radius<input type="range" data-k="radius" min="0" max="28" step="1" /><output></output></label>
        <label class="pp-knob">glyph size<input type="range" data-k="glyph" min="60" max="160" step="5" /><output></output></label>
        <label class="pp-knob">hue tint<input type="range" data-k="tint" min="0" max="60" step="1" /><output></output></label>
        <label class="pp-knob">bar (A)<input type="range" data-k="bar" min="0" max="8" step="1" /><output></output></label>
        <label class="pp-knob">gradient (B)<input type="range" data-k="grad" min="0" max="90" step="5" /><output></output></label>
        <label class="pp-knob">hero art<input type="range" data-k="hero" min="120" max="220" step="4" /><output></output></label>
        <label class="pp-knob">title weight<input type="range" data-k="tw" min="500" max="900" step="50" /><output></output></label>
        <label class="pp-knob">title track<input type="range" data-k="tt" min="-2.5" max="0.5" step="0.1" /><output></output></label>
        <label class="pp-knob">row density<input type="range" data-k="den" min="6" max="16" step="1" /><output></output></label>
        <label class="pp-toggle"><input type="checkbox" data-t="lc" /> lowercase titles</label>
        <label class="pp-toggle"><input type="checkbox" data-t="th" /> art in rows</label>
      </div>
    </aside>

    <div class="proto-phone" hidden>
      <div class="pp-shell">
        <button class="pp-close" type="button">✕ close (esc)</button>
        <div class="pp-frame"><iframe title="Phone preview"></iframe></div>
      </div>
    </div>

    <style is:global>
      /* no-JS baseline = the picked defaults; the head script overrides per URL */
      :root {
        --k-radius: 12; --k-glyph: 85; --k-tint: 23; --k-bar: 4; --k-grad: 35;
        --k-hero: 180; --k-tw: 650; --k-tt: -1.2; --k-den: 16;
      }

      /* ════════ knob plumbing — covers (all tiles: hero, rows, cards, bar, sidebar) ════════ */
      .art, .pb-art, .pl .alb {
        border-radius: calc(var(--k-radius, 12) * 1px);
        background: color-mix(in oklab, var(--pl-tile), var(--a, var(--pl-accent)) calc(var(--k-tint, 8) * 1%));
      }
      .pb-art { border-radius: calc(var(--k-radius, 12) * 0.66px); font-size: calc(15px * var(--k-glyph, 100) / 100); }
      .pl .alb { border-radius: calc(var(--k-radius, 12) * 0.5px); font-size: calc(9px * var(--k-glyph, 100) / 100); }
      .proto-home .art.lg {
        width: min(calc(var(--k-hero, 176) * 1px), 34vw);
        height: min(calc(var(--k-hero, 176) * 1px), 34vw);
        font-size: calc(var(--k-hero, 176) * 0.24px * var(--k-glyph, 100) / 100);
      }

      /* cover A — flat tile + accent bar (current), bar height is a knob */
      html[data-cover='A'] :is(.art, .pb-art, .pl .alb)::after { height: calc(var(--k-bar, 5) * 1px); }

      /* cover B — duotone gradient, glow highlight, no bar */
      html[data-cover='B'] :is(.art, .pb-art, .pl .alb) {
        background:
          radial-gradient(120% 90% at 28% 22%, rgb(255 255 255 / 0.13), transparent 55%),
          linear-gradient(
            135deg,
            color-mix(in oklab, var(--a, var(--pl-accent)) calc(var(--k-grad, 55) * 1%), var(--pl-tile)),
            color-mix(in oklab, var(--a, var(--pl-accent)) calc(var(--k-grad, 55) * 0.3%), var(--pl-tile)) 62%,
            var(--pl-tile)
          );
        color: color-mix(in oklab, var(--a, var(--pl-accent)) 28%, #f2f3f7);
        border-color: color-mix(in oklab, var(--a, var(--pl-accent)) 35%, var(--pl-tile-line));
        font-weight: 600;
      }
      html[data-cover='B'] :is(.art, .pb-art, .pl .alb)::after { display: none; }

      /* cover C — framed poster: tinted paper, thin inner frame, spaced caps */
      html[data-cover='C'] :is(.art, .pb-art, .pl .alb) {
        background: color-mix(in oklab, var(--pl-tile), var(--a, var(--pl-accent)) calc(8% + var(--k-tint, 8) * 1%));
        color: color-mix(in oklab, var(--a, var(--pl-accent)) 70%, #e6e8ed);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        text-indent: 0.14em;
        font-weight: 500;
      }
      html[data-cover='C'] :is(.art, .pb-art, .pl .alb)::after {
        top: 7%; left: 7%; right: 7%; bottom: 7%; height: auto;
        background: transparent;
        border: 1px solid color-mix(in oklab, var(--a, var(--pl-accent)) 55%, transparent);
        border-radius: calc(var(--k-radius, 12) * 0.4px);
      }

      /* cover D — vinyl: grooved disc with a hue label; glyph only on big tiles */
      html[data-cover='D'] :is(.art, .pb-art, .pl .alb) {
        background:
          radial-gradient(
            circle at 50% 50%,
            #101116 0 4%,
            var(--a, var(--pl-accent)) 4.5% 24%,
            #0d0e12 24.5% 26.5%,
            transparent 27%
          ),
          repeating-radial-gradient(circle at 50% 50%, #16171c 0 4.5%, #1e2027 4.5% 6.5%);
        color: rgb(10 10 14 / 0.78);
      }
      html[data-cover='D'] :is(.art, .pb-art, .pl .alb)::after { display: none; }
      html[data-cover='D'] .proto-home .art.lg { font-size: calc(var(--k-hero, 176) * 0.1px * var(--k-glyph, 100) / 100); }
      html[data-cover='D'] :is(.pb-art, .pl .alb, .row-art) { color: transparent; }

      /* ════════ knob plumbing — titles + rows ════════ */
      .hero h1, .btitle, .bb-title {
        font-weight: var(--k-tw, 800);
        letter-spacing: calc(var(--k-tt, -1.5) * 1px);
      }
      html.k-lc :is(.hero h1, .btitle, .bb-title, .track .t b, .pb-now b, .ccard b, .brail b) { text-transform: lowercase; }
      .track { padding-top: calc(var(--k-den, 10) * 1px); padding-bottom: calc(var(--k-den, 10) * 1px); }

      /* per-row cover thumbs (knob: art in rows; forced by mobile C) */
      .row-art, .row-art-h { display: none; }
      .row-art {
        width: 36px; height: 36px;
        border-radius: calc(var(--k-radius, 12) * 0.5px);
        font-size: calc(11px * var(--k-glyph, 100) / 100);
      }
      html.k-th .track .row-art { display: grid; }
      html.k-th .list-head .row-art-h { display: block; }
      html.k-th .list-head, html.k-th .track { grid-template-columns: 34px 44px 1fr 180px 120px 90px; }

      /* ════════ home B — artist profile ════════ */
      .proto-home { display: none; }
      html[data-home='A'] [data-home-view='A'],
      html[data-home='B'] [data-home-view='B'],
      html[data-home='C'] [data-home-view='C'] { display: block; }

      .bhead {
        display: flex; gap: 22px; align-items: center;
        padding: 36px 30px 26px;
        border-bottom: 1px solid var(--pl-line);
        background: linear-gradient(180deg, color-mix(in oklab, var(--a, var(--pl-accent)) 14%, transparent), transparent 92%);
      }
      .bavatar {
        width: 92px; height: 92px; border-radius: 50%; flex-shrink: 0;
        background: linear-gradient(135deg, color-mix(in oklab, var(--pl-accent) 45%, var(--pl-tile)), var(--pl-tile));
        border: 1px solid var(--pl-tile-line);
        display: grid; place-items: center;
        font-weight: 700; font-size: 24px; letter-spacing: 1px; color: #fff;
      }
      .btitle { font-size: clamp(30px, 5vw, 52px); margin: 4px 0 10px; line-height: 1.05; }
      .bstats { color: var(--pl-faint); font-size: 12.5px; display: flex; gap: 14px; flex-wrap: wrap; }
      .bstats b { color: var(--pl-text); font-weight: 600; }

      .brail {
        display: grid; grid-auto-flow: column; grid-auto-columns: 132px;
        gap: 14px; overflow-x: auto; padding: 4px 2px 16px;
        scrollbar-width: none;
      }
      .brail::-webkit-scrollbar { display: none; }
      .brail a { display: grid; gap: 2px; align-content: start; }
      .brail .art { width: 132px; height: 132px; font-size: calc(26px * var(--k-glyph, 100) / 100); margin-bottom: 6px; }
      .brail b { font-size: 12.5px; font-weight: 600; }
      .brail small { color: var(--pl-faint); font-size: 11px; }

      /* ════════ home C — billboard + pinned grid ════════ */
      .bb {
        padding: 58px 30px 34px;
        border-bottom: 1px solid var(--pl-line);
        background: linear-gradient(
          165deg,
          color-mix(in oklab, var(--a, var(--pl-accent)) 34%, var(--pl-bg)) 0%,
          color-mix(in oklab, var(--a, var(--pl-accent)) 10%, var(--pl-bg)) 55%,
          var(--pl-bg) 100%
        );
      }
      .bb .kind { font-size: 11px; font-weight: 600; letter-spacing: 1.4px; text-transform: uppercase; color: var(--pl-dim); }
      .bb-title { font-size: clamp(40px, 7.5vw, 76px); line-height: 1.02; margin: 8px 0 12px; max-width: 16ch; }
      .bb p { color: var(--pl-dim); max-width: 60ch; font-size: 13.5px; }
      .bb-actions { display: flex; gap: 16px; align-items: center; margin-top: 24px; flex-wrap: wrap; }

      .cgrid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 14px; padding-bottom: 10px;
      }
      .ccard {
        background: var(--pl-panel); border: 1px solid var(--pl-line);
        border-radius: 12px; padding: 12px;
        display: grid; gap: 4px; align-content: start;
        transition: background 0.12s;
      }
      .ccard:hover { background: var(--pl-panel-hi); }
      .ccard .art { width: 100%; aspect-ratio: 1; height: auto; font-size: calc(34px * var(--k-glyph, 100) / 100); margin-bottom: 6px; }
      .ccard b { font-size: 13.5px; font-weight: 600; }
      .ccard small { color: var(--pl-dim); font-size: 12px; }
      .ccard-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }

      /* head sections of B/C match the shell's mobile padding rhythm */
      @media (max-width: 820px) {
        .bhead { padding: 22px 18px 18px; gap: 14px; }
        .bavatar { width: 64px; height: 64px; font-size: 18px; }
        .bb { padding: 32px 18px 24px; }
      }

      /* mobile shell (tab bar + mini player) now lives in player.css for the
         whole site; the only proto-specific mobile rule left is the row-art
         column when the art-in-rows knob is on. */
      @media (max-width: 820px) {
        html.k-th .list-head, html.k-th .track { grid-template-columns: 30px 44px 1fr 70px; }
      }

      /* ════════ prototype chrome — obviously not part of the design ════════ */
      .proto-panel {
        position: fixed; left: 50%; transform: translateX(-50%);
        bottom: 96px; z-index: 80;
        background: #07080a; border: 1px solid #454a58; border-radius: 13px;
        box-shadow: 0 12px 40px rgb(0 0 0 / 0.6);
        font-family: var(--pl-mono); font-size: 11.5px; color: #c9cdd8;
        user-select: none;
        max-width: min(96vw, 760px);
      }
      .pp-row { display: flex; gap: 6px; align-items: center; padding: 8px 10px; flex-wrap: wrap; justify-content: center; }
      .pp-grp { display: flex; align-items: center; gap: 4px; border: 1px solid #2e323d; border-radius: 9px; padding: 3px 6px; }
      .pp-grp .lbl { color: #7e8493; text-transform: uppercase; font-size: 9.5px; letter-spacing: 0.8px; margin-right: 2px; }
      .pp-grp button { color: #c9cdd8; padding: 2px 6px; font-size: 13px; }
      .pp-grp button:hover { color: #fff; }
      .pp-grp .val { min-width: 110px; text-align: center; color: #fff; }
      .pp-actions { display: flex; gap: 5px; }
      .pp-actions button { border: 1px solid #2e323d; border-radius: 9px; padding: 5px 9px; color: #c9cdd8; }
      .pp-actions button:hover { color: #fff; border-color: #555b6b; }
      .pp-knobs {
        display: none; grid-template-columns: repeat(3, auto);
        gap: 8px 20px; padding: 10px 14px 12px;
        border-top: 1px solid #23262e;
      }
      .proto-panel.open .pp-knobs { display: grid; }
      .pp-knob { display: flex; align-items: center; gap: 8px; }
      .pp-knob input[type='range'] { width: 104px; accent-color: #8b7cf6; }
      .pp-knob output { width: 40px; text-align: right; color: #fff; }
      .pp-toggle { display: flex; gap: 7px; align-items: center; color: #8d93a3; }
      @media (max-width: 820px) {
        .proto-panel { bottom: 150px; }
        .pp-knobs { grid-template-columns: 1fr; }
      }

      .proto-phone {
        position: fixed; inset: 0; z-index: 90;
        background: rgb(0 0 0 / 0.65);
        display: grid; place-items: center;
      }
      .proto-phone[hidden] { display: none; }
      .pp-shell { position: relative; }
      .pp-frame {
        border: 10px solid #2a2d36; border-radius: 36px; overflow: hidden;
        box-shadow: 0 30px 80px rgb(0 0 0 / 0.7);
      }
      .pp-frame iframe { width: 390px; height: min(760px, 88vh); border: 0; display: block; background: var(--pl-bg); }
      .pp-close {
        position: absolute; top: -32px; right: 0;
        color: #fff; font-family: var(--pl-mono); font-size: 12px;
      }

      html.k-embed :is(.proto-panel, .proto-phone) { display: none !important; }
    </style>

    <script is:inline>
      // Prototype chrome: variant cyclers, knobs, phone preview. State → URL.
      (() => {
        const d = document.documentElement;
        if (d.classList.contains('k-embed')) return;

        const DIMS = { home: ['A', 'B', 'C'], cover: ['A', 'B', 'C', 'D'] };
        const DEF = { home: 'B', cover: 'C' };
        const NAMES = {
          home: { A: 'now playing', B: 'artist profile', C: 'billboard' },
          cover: { A: 'accent bar', B: 'gradient', C: 'framed', D: 'vinyl' },
        };
        const KN = {
          radius: [0, 28, 12], glyph: [60, 160, 85], tint: [0, 60, 23],
          bar: [0, 8, 4], grad: [0, 90, 35], hero: [120, 220, 180],
          tw: [500, 900, 650], tt: [-2.5, 0.5, -1.2], den: [6, 16, 16],
        };

        const q = new URLSearchParams(location.search);
        const state = {
          home: d.dataset.home, cover: d.dataset.cover,
          lc: d.classList.contains('k-lc'), th: d.classList.contains('k-th'),
        };
        for (const k in KN) {
          let v = parseFloat(q.get(k));
          if (Number.isNaN(v)) v = KN[k][2];
          state[k] = Math.min(KN[k][1], Math.max(KN[k][0], v));
        }

        const panel = document.querySelector('.proto-panel');
        const phone = document.querySelector('.proto-phone');
        const frame = phone.querySelector('iframe');

        const urlOf = (embed) => {
          const p = new URLSearchParams();
          for (const dim in DIMS) if (state[dim] !== DEF[dim]) p.set(dim, state[dim]);
          for (const k in KN) if (state[k] !== KN[k][2]) p.set(k, String(state[k]));
          if (state.lc) p.set('lc', '1');
          if (!state.th) p.set('th', '0');
          if (embed) p.set('embed', '1');
          const s = p.toString();
          return location.pathname + (s ? '?' + s : '');
        };

        const render = () => {
          panel.querySelectorAll('.pp-grp').forEach((g) => {
            const dim = g.dataset.dim;
            g.querySelector('.val').textContent = state[dim] + ' · ' + NAMES[dim][state[dim]];
          });
          panel.querySelectorAll('input[data-k]').forEach((inp) => {
            inp.value = String(state[inp.dataset.k]);
            inp.closest('.pp-knob').querySelector('output').textContent = String(state[inp.dataset.k]);
          });
          panel.querySelectorAll('input[data-t]').forEach((inp) => { inp.checked = !!state[inp.dataset.t]; });
        };

        let frameTimer;
        const sync = () => {
          for (const dim in DIMS) d.dataset[dim] = state[dim];
          for (const k in KN) d.style.setProperty('--k-' + k, String(state[k]));
          d.classList.toggle('k-lc', state.lc);
          d.classList.toggle('k-th', state.th);
          history.replaceState(null, '', urlOf(false));
          clearTimeout(frameTimer);
          frameTimer = setTimeout(() => { if (!phone.hidden) frame.src = urlOf(true); }, 350);
          render();
        };

        let lastDim = 'home';
        const cycle = (dim, dir) => {
          const order = DIMS[dim];
          state[dim] = order[(order.indexOf(state[dim]) + dir + order.length) % order.length];
          lastDim = dim;
          sync();
        };

        panel.querySelectorAll('.pp-grp').forEach((g) => {
          const dim = g.dataset.dim;
          g.querySelector('[data-prev]').addEventListener('click', () => cycle(dim, -1));
          g.querySelector('[data-next]').addEventListener('click', () => cycle(dim, 1));
          g.addEventListener('click', () => { lastDim = dim; });
        });
        panel.querySelectorAll('input[data-k]').forEach((inp) => {
          inp.addEventListener('input', () => { state[inp.dataset.k] = parseFloat(inp.value); sync(); });
        });
        panel.querySelectorAll('input[data-t]').forEach((inp) => {
          inp.addEventListener('change', () => { state[inp.dataset.t] = inp.checked; sync(); });
        });
        panel.querySelector('[data-knobs]').addEventListener('click', () => panel.classList.toggle('open'));
        panel.querySelector('[data-reset]').addEventListener('click', () => {
          for (const dim in DIMS) state[dim] = DEF[dim];
          for (const k in KN) state[k] = KN[k][2];
          state.lc = false; state.th = true;
          sync();
        });
        panel.querySelector('[data-copy]').addEventListener('click', (e) => {
          navigator.clipboard.writeText(location.origin + urlOf(false)).then(() => {
            e.target.textContent = 'copied!';
            setTimeout(() => { e.target.textContent = 'copy url'; }, 1200);
          });
        });
        panel.querySelector('[data-phone]').addEventListener('click', () => {
          phone.hidden = !phone.hidden;
          if (!phone.hidden) frame.src = urlOf(true);
        });
        phone.querySelector('.pp-close').addEventListener('click', () => { phone.hidden = true; });
        phone.addEventListener('click', (e) => { if (e.target === phone) phone.hidden = true; });

        document.addEventListener('keydown', (e) => {
          const t = e.target;
          if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
          if (e.key === 'Escape' && !phone.hidden) { phone.hidden = true; return; }
          if (e.key === 'ArrowLeft') { e.preventDefault(); cycle(lastDim, -1); }
          if (e.key === 'ArrowRight') { e.preventDefault(); cycle(lastDim, 1); }
        });

        render();
      })();
    </script>
  </body>
</html>
