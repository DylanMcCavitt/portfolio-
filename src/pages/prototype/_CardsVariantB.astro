---
/**
 * PROTOTYPE — Cards variant B · "Typographic" (throwaway, do not ship).
 *
 * The antithesis of the screenshot variant: zero imagery, no tile. A project's
 * identity comes from type + color only. Each entry is a flat, typeset row in an
 * editorial index — a monospace project id as the sole "mark", a strong title, a
 * justified meta line (area · year / status badge / activity), and the tagline
 * in dim. Hue is a fine accent: a hairline top rule carries a short hue tick that
 * strengthens (extends full-width, brightens) on hover, and the id/title pick up
 * the hue. Surfaces stay flat (no boxes); hairlines + whitespace do the framing.
 *
 * No image handling needed — the design is image-free by intent, so projects with
 * and without screenshots (e.g. `hood`) render identically.
 */
import type { Project } from '../../data/catalog';

export interface Props {
  projects: Project[];
}
const { projects } = Astro.props;
---

<section class="twrap">
  <header class="thead">
    <p class="tkicker">Variant B — Typographic</p>
    <p class="tsub">No icon, no tile. Identity is type + color; the monospace id is the only mark.</p>
  </header>

  <div class="tgrid">
    {
      projects.map((project) => {
        const [kind, label] = project.status;
        return (
          <a
            class="tcard"
            href={`/prototype/project/${project.id}`}
            style={`--hue:${project.hue}`}
          >
            <span class="tcard__rule" aria-hidden="true" />
            <span class="tcard__id">{project.id}</span>
            <h3 class="tcard__title">{project.title}</h3>
            <div class="tcard__meta">
              <span class="tcard__cat">
                {project.area} · {project.year}
              </span>
              <span class={`badge ${kind}`}>{label}</span>
              <span class="tcard__act">{project.activity}</span>
            </div>
            <p class="tcard__line">{project.line}</p>
          </a>
        );
      })
    }
  </div>
</section>

<style>
  .twrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 60px 36px 104px;
  }

  /* --- design label --- */
  .thead {
    margin-bottom: 40px;
  }
  .tkicker {
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .tsub {
    margin-top: 6px;
    font-size: 13px;
    color: var(--pl-dim);
  }

  /* --- editorial index grid (flat, hairline-separated) --- */
  .tgrid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    column-gap: 56px;
  }

  /* --- one card: flat, a hairline top rule with a hue tick --- */
  .tcard {
    position: relative;
    display: block;
    padding: 24px 0 28px;
    border-top: 1px solid var(--pl-line);
    color: inherit;
  }
  /* the only color mark on the surface: a short hue segment on the top rule */
  .tcard__rule {
    position: absolute;
    top: -1px;
    left: 0;
    height: 2px;
    width: 40px;
    background: var(--hue);
    opacity: 0.82;
    transition:
      width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease;
  }

  .tcard__id {
    display: block;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--hue) 58%, var(--pl-faint));
    transition: color 0.18s ease;
  }

  .tcard__title {
    margin-top: 11px;
    font-size: clamp(21px, 2.3vw, 27px);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--pl-text);
    overflow-wrap: break-word;
    transition: color 0.18s ease;
  }

  .tcard__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 14px;
  }
  .tcard__cat {
    font-size: 12.5px;
    color: var(--pl-faint);
  }
  .tcard__act {
    margin-left: auto;
    font-family: var(--pl-mono);
    font-size: 11px;
    color: var(--pl-faint);
  }

  .tcard__line {
    margin-top: 15px;
    max-width: 48ch;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--pl-dim);
  }

  /* --- hover/focus: hue accent strengthens, type warms --- */
  .tcard:hover .tcard__rule,
  .tcard:focus-visible .tcard__rule {
    width: 100%;
    opacity: 1;
  }
  .tcard:hover .tcard__id,
  .tcard:focus-visible .tcard__id {
    color: var(--hue);
  }
  .tcard:hover .tcard__title,
  .tcard:focus-visible .tcard__title {
    color: color-mix(in srgb, var(--hue) 22%, var(--pl-text));
  }
  .tcard:focus-visible {
    outline: 2px solid var(--pl-focus);
    outline-offset: 4px;
  }

  @media (max-width: 820px) {
    .twrap {
      padding: 40px 20px 72px;
    }
    .tgrid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tcard__rule,
    .tcard__id,
    .tcard__title {
      transition: none;
    }
  }
</style>
