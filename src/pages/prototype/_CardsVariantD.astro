---
/**
 * PROTOTYPE — card + icon variant D: "Generative".
 *
 * The icon is a DISTINCT abstract emblem generated deterministically from each
 * project's `id` (FNV-1a hash → mulberry32 PRNG) and tinted with `project.hue`.
 * One of four shape families (orbits / constellation field / equalizer strata /
 * faceted gem) is chosen by the hash, so every project gets a stable, unique,
 * recognizable mark — never the retired 2-letter monogram, no screenshots
 * needed (so the no-image projects like `hood` need no fallback here).
 *
 * Card = bordered tile in an auto-fill grid: generated mark + status badge on
 * the top row, then title, `area · year`, the tagline `line`, and a faint mono
 * `activity` line. Hue accent drives the hover glow. Whole card links to the
 * detail prototype. Scoped styles only.
 */
import type { Project } from '../../data/catalog';
import { genMarkSvg } from './_cardsMarkD';
export interface Props {
  projects: Project[];
}
const { projects } = Astro.props;

const cards = projects.map((p) => ({ p, svg: genMarkSvg(p.id, p.hue) }));
---

<section class="wrap">
  <p class="label">Generative — abstract mark hashed from each project</p>
  <div class="grid">
    {
      cards.map(({ p, svg }) => (
        <a class="gcard" href={`/prototype/project/${p.id}`} style={`--hue:${p.hue}`}>
          <div class="gtop">
            <span class="mark" set:html={svg} />
            <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
          </div>
          <h3 class="gtitle">{p.title}</h3>
          <p class="gmeta">
            {p.area} <span class="dot">·</span> {p.year}
          </p>
          <p class="gline">{p.line}</p>
          <p class="gact">{p.activity}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 40px 24px 72px;
  }
  .label {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pl-faint);
  }
  .label::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--pl-line);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .gcard {
    display: flex;
    flex-direction: column;
    gap: 9px;
    padding: 18px;
    border-radius: 16px;
    background: var(--pl-panel);
    border: 1px solid var(--pl-line);
    transition:
      transform 0.16s ease,
      border-color 0.16s ease,
      box-shadow 0.16s ease,
      background 0.16s ease;
  }
  .gcard:hover,
  .gcard:focus-visible {
    transform: translateY(-3px);
    background: var(--pl-panel-hi);
    border-color: color-mix(in srgb, var(--hue) 55%, var(--pl-line));
    box-shadow: 0 14px 34px -16px color-mix(in srgb, var(--hue) 70%, transparent);
    outline: none;
  }

  .gtop {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 2px;
  }
  .mark {
    flex: 0 0 auto;
    width: 54px;
    height: 54px;
    display: block;
    border-radius: 14px;
  }
  .mark :global(svg) {
    display: block;
  }

  .gtitle {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--pl-text);
  }
  .gmeta {
    font-size: 12px;
    color: var(--pl-dim);
  }
  .gmeta .dot {
    color: color-mix(in srgb, var(--hue) 60%, var(--pl-dim));
    margin: 0 2px;
  }
  .gline {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--pl-faint);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .gact {
    margin-top: 2px;
    font-family: var(--pl-mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: color-mix(in srgb, var(--hue) 32%, var(--pl-faint));
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .wrap {
      padding: 28px 16px 56px;
    }
  }
</style>
