---
/**
 * PROTOTYPE — throwaway. Tracklist copy of LibraryView's rows with one
 * addition: an optional per-row cover thumb (`.row-art`), revealed by the
 * "art in rows" knob (html.k-th) or forced on by mobile variant C.
 * Underscore-prefixed so Astro doesn't route it. Delete with the prototype.
 */
import type { Project } from '../../data/catalog';

export interface Props {
  list: Project[];
  now?: Project;
}
const { list, now } = Astro.props;
---

<div class="list-head">
  <span>#</span>
  <span class="row-art-h" aria-hidden="true"></span>
  <span>Title</span>
  <span class="album">Area</span>
  <span class="stat-col">Status</span>
  <span style="text-align:right">Activity</span>
</div>
<ol class="tracklist">
  {
    list.map((p, i) => {
      const playing = now && p.id === now.id;
      return (
        <li>
          <a class:list={['track', { playing }]} href={`/projects/${p.id}`}>
            <span class="n">
              <span class="eq" aria-hidden="true">
                <i />
                <i />
                <i />
              </span>
              <span class="num">{i + 1}</span>
              <span class="hoverplay" aria-hidden="true" />
            </span>
            <span class="row-art art" style={`--a:${p.hue}`} aria-hidden="true">{p.sym}</span>
            <span class="t">
              <b>{p.title}</b>
              <small>{p.line}</small>
            </span>
            <span class="album">{p.area}</span>
            <span class="stat-col">
              <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
            </span>
            <span class="len">{p.activity}</span>
          </a>
        </li>
      );
    })
  }
</ol>
