---
/**
 * PROTOTYPE variant C — "Line icon" cards (throwaway, do not ship).
 *
 * Replaces the disliked 2-letter hue tile with a real iconographic system: a
 * tasteful inline-SVG line glyph chosen by the project's `area` (candlesticks
 * for trading, a node graph for agents, a phone for iOS, stacked servers for
 * infra, a flask for research, a package for shipped, a mortarboard for
 * school; sparkles as the fallback). Layout is a compact, row-based list — a
 * hue-tinted icon chip on the left, scannable content on the right — so it
 * reads distinctly from the image-led / typographic / generative variants.
 *
 * Receives the curated project set from the route; renders only the cards.
 */
import type { Project, ProjectArea } from '../../data/catalog';

export interface Props {
  projects: Project[];
}
const { projects } = Astro.props;

// Inner SVG for a shared 24px / 1.5px-stroke / round-cap line-icon frame.
// `currentColor` everywhere so the chip's hue drives the stroke. Authored as a
// fixed lookup (no user input) → safe to inject with `set:html`.
const ICONS: Record<ProjectArea, string> = {
  // candlestick chart
  'Trading systems':
    '<line x1="6" y1="3" x2="6" y2="13"/><rect x="4.3" y="5" width="3.4" height="6" rx="1"/><line x1="12" y1="6" x2="12" y2="21"/><rect x="10.3" y="9" width="3.4" height="8" rx="1"/><line x1="18" y1="4" x2="18" y2="16"/><rect x="16.3" y="7" width="3.4" height="6" rx="1"/>',
  // connected nodes / graph
  'Agents & MCP':
    '<line x1="7.7" y1="9.6" x2="16.3" y2="6.8"/><line x1="7.6" y1="10.9" x2="14.6" y2="16.1"/><line x1="17.2" y1="8.2" x2="16.3" y2="15.6"/><circle cx="6" cy="9" r="2.4"/><circle cx="18" cy="6.2" r="2.4"/><circle cx="16" cy="17.8" r="2.4"/>',
  // phone
  iOS: '<rect x="6.5" y="2.5" width="11" height="19" rx="2.6"/><line x1="10.6" y1="5" x2="13.4" y2="5"/><line x1="10.3" y1="18.7" x2="13.7" y2="18.7"/>',
  // stacked servers (round-cap dots = LEDs)
  Infrastructure:
    '<rect x="3.5" y="4" width="17" height="6" rx="1.6"/><rect x="3.5" y="14" width="17" height="6" rx="1.6"/><line x1="6.8" y1="7" x2="6.81" y2="7"/><line x1="6.8" y1="17" x2="6.81" y2="17"/>',
  // erlenmeyer flask
  Research:
    '<path d="M8 3h8"/><path d="M9.5 3v6.2L5 18.4c-.5 1 .2 2.1 1.3 2.1h11.4c1.1 0 1.8-1.1 1.3-2.1L14.5 9.2V3"/><line x1="8" y1="14.8" x2="16" y2="14.8"/>',
  // shipped package
  Shipped:
    '<path d="M21 7.5 12 3 3 7.5v9L12 21l9-4.5z"/><path d="M3.3 7.7 12 12l8.7-4.3"/><path d="M12 12v9"/><path d="M7.5 5.2 16.5 9.7"/>',
  // mortarboard
  School:
    '<path d="M2.5 9 12 4.5 21.5 9 12 13.5z"/><path d="M6 11.2v4.3c0 1.2 2.7 2.4 6 2.4s6-1.2 6-2.4v-4.3"/><path d="M21.5 9v4.2"/><line x1="21.5" y1="13.4" x2="21.51" y2="13.4"/>',
};
// Generic sparkles fallback for any future area.
const FALLBACK_ICON =
  '<path d="M12 3.2l1.7 5.6 5.6 1.7-5.6 1.7L12 17.8l-1.7-5.6L4.7 10.5l5.6-1.7z"/><path d="M18.6 3.5l.6 2 2 .6-2 .6-.6 2-.6-2-2-.6 2-.6z"/>';
const iconFor = (area: ProjectArea): string => ICONS[area] ?? FALLBACK_ICON;
---

<section class="cv">
  <p class="cv-label">Line icon — semantic SVG glyph chosen by area, hue-accented</p>
  <ul class="cv-grid">
    {
      projects.map((p) => (
        <li>
          <a class="row" href={`/prototype/project/${p.id}`} style={`--hue:${p.hue}`}>
            <span class="chip" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={iconFor(p.area)}
              />
            </span>
            <span class="body">
              <span class="head">
                <span class="title">{p.title}</span>
                <span class:list={['badge', p.status[0]]}>{p.status[1]}</span>
              </span>
              <span class="meta">
                {p.area} · {p.year} · {p.activity}
              </span>
              <span class="line">{p.line}</span>
            </span>
            <svg class="go" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 6l6 6-6 6" />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .cv {
    padding: 28px clamp(16px, 4vw, 40px) 72px;
    max-width: 1120px;
    margin: 0 auto;
  }
  .cv-label {
    margin: 0 0 18px;
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--pl-faint);
  }

  .cv-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  .cv-grid > li {
    display: flex;
    min-width: 0;
  }

  /* ---- row ---- */
  .row {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1 1 auto;
    min-width: 0;
    padding: 14px 16px;
    border: 1px solid var(--pl-line);
    border-radius: 14px;
    background: var(--pl-panel);
    color: var(--pl-text);
    text-decoration: none;
    transition:
      border-color 0.15s,
      background 0.15s,
      transform 0.15s,
      box-shadow 0.15s;
  }
  .row:hover {
    border-color: color-mix(in srgb, var(--hue) 50%, var(--pl-line));
    background: var(--pl-panel-hi);
    transform: translateY(-1px);
    box-shadow: 0 10px 26px -20px color-mix(in srgb, var(--hue) 80%, #000);
  }
  .row:focus-visible {
    outline: 2px solid var(--pl-focus);
    outline-offset: 2px;
  }

  /* ---- hue icon chip ---- */
  .chip {
    flex: 0 0 auto;
    width: 46px;
    height: 46px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    color: var(--hue);
    background: color-mix(in srgb, var(--hue) 13%, var(--pl-tile));
    border: 1px solid color-mix(in srgb, var(--hue) 26%, var(--pl-tile-line));
    transition:
      background 0.15s,
      border-color 0.15s;
  }
  .row:hover .chip {
    background: color-mix(in srgb, var(--hue) 20%, var(--pl-tile));
    border-color: color-mix(in srgb, var(--hue) 42%, var(--pl-tile-line));
  }
  .chip svg {
    width: 25px;
    height: 25px;
    display: block;
  }

  /* ---- content ---- */
  .body {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .head {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .title {
    flex: 1 1 auto;
    min-width: 0;
    font-size: 14.5px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .head .badge {
    flex: 0 0 auto;
  }
  .meta {
    font-family: var(--pl-mono);
    font-size: 11px;
    letter-spacing: 0.3px;
    color: var(--pl-faint);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .line {
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--pl-dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- chevron affordance ---- */
  .go {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    align-self: center;
    color: var(--pl-faint);
    opacity: 0.35;
    transform: translateX(-3px);
    transition:
      opacity 0.15s,
      transform 0.15s,
      color 0.15s;
  }
  .row:hover .go {
    opacity: 1;
    transform: translateX(0);
    color: var(--hue);
  }

  @media (max-width: 820px) {
    .cv-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
